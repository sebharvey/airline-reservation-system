    },
    {
      "step": 16,
      "name": "Retrieve booking for check-in (inbound)",
      "description": "Look up the booking by reference, lead passenger name, and departure airport JFK to open the inbound check-in session. Returns the list of passengers with ticket numbers for the inbound flight segment. checkInEligible confirms the booking is within the 24-hour check-in window for the return leg.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/oci/retrieve",
        "baseUrlRef": "operations"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "bookingReference": "__CHAIN_bookingReference__",
          "firstName": "__RAND_GIVEN_NAME__",
          "lastName": "__RAND_SURNAME__",
          "departureAirport": "JFK"
        },
