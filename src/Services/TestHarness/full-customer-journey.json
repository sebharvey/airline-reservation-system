    {
      "step": 14,
      "name": "Complete check-in",
      "description": "Final check-in submission. The Operations API retrieves the order to resolve all ticket numbers, then calls the Delivery microservice to update each ticket coupon status to C (checked in). Returns an array of checked-in ticket numbers.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/oci/checkin",
