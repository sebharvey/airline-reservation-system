{
  "journey": {
    "name": "Timatic Simulator \u2014 autocheck endpoints",
    "description": "End-to-end journey covering all three IATA AutoCheck simulator endpoints: document check (with and without US ESTA advisory), APIS check, and realtime gate MRZ check. Negative steps verify that missing or wrong Authorization headers return 401. Positive steps send Authorization: Bearer timatic-test-2026 \u2014 the Timatic:ApiToken Azure App Setting on the simulator must be set to timatic-test-2026 for positive steps to pass.",
    "domain": "Simulator",
    "baseUrls": [
      {
        "id": "timatic",
        "label": "Timatic Simulator",
        "url": "https://reservation-system-simulator-timatic-h0guaxfvgaengdeh.uksouth-01.azurewebsites.net"
      }
    ]
  },
  "steps": [
    {
      "step": 1,
      "name": "Document check \u2014 LHR\u2192JFK (ESTA)",
      "description": "POST a document check for a British passport holder travelling LHR\u2192JFK. The simulator inspects the final arrival airport (JFK) and appends an ESTA advisory because JFK is a US gateway. All other requirement flags (visaRequired, healthDocRequired, transitVisaRequired) are false.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/autocheck/v1/documentcheck",
        "baseUrlRef": "timatic",
        "note": "Authorization header must match the Timatic:ApiToken app setting"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer timatic-test-2026"
        },
        "body": {
          "transactionIdentifier": "TXN-2026-DOC-001",
          "airlineCode": "AX",
          "journeyType": "OW",
          "paxInfo": {
            "documentType": "P",
            "nationality": "GBR",
            "documentIssuerCountry": "GBR",
            "documentNumber": "__RAND_DOC_NUMBER__",
            "documentExpiryDate": "__RAND_DOC_EXPIRY__",
            "dateOfBirth": "__RAND_DOB__",
            "gender": "__RAND_GENDER_CODE__",
            "residentCountry": "GBR"
          },
          "itinerary": [
            {
              "departureAirport": "LHR",
              "arrivalAirport": "JFK",
              "airline": "AX",
              "flightNumber": "AX001",
              "departureDate": "__RAND_DEPART_DATE__"
            }
          ]
        }
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200,
        "assertions": [
          {
            "field": "advisories",
            "assertion": "count",
            "expected": 1
          }
        ]
      },
      "chainsTo": []
    },
    {
      "step": 2,
      "name": "Document check \u2014 LHR\u2192CDG (no advisory)",
      "description": "POST a document check for a British passport holder travelling LHR\u2192CDG. CDG is not a US gateway so no advisory is appended. Confirms the simulator only adds the ESTA advisory for US destinations.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/autocheck/v1/documentcheck",
        "baseUrlRef": "timatic"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer timatic-test-2026"
        },
        "body": {
          "transactionIdentifier": "TXN-2026-DOC-002",
          "airlineCode": "AX",
          "journeyType": "OW",
          "paxInfo": {
            "documentType": "P",
            "nationality": "GBR",
            "documentIssuerCountry": "GBR",
            "documentNumber": "__RAND_DOC_NUMBER__",
            "documentExpiryDate": "__RAND_DOC_EXPIRY__",
            "dateOfBirth": "__RAND_DOB__",
            "gender": "__RAND_GENDER_CODE__",
            "residentCountry": "GBR"
          },
          "itinerary": [
            {
              "departureAirport": "LHR",
              "arrivalAirport": "CDG",
              "airline": "AX",
              "flightNumber": "AX010",
              "departureDate": "__RAND_DEPART_DATE__"
            }
          ]
        }
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200,
        "assertions": [
          {
            "field": "advisories",
            "assertion": "count",
            "expected": 0
          }
        ]
      },
      "chainsTo": []
    },
    {
      "step": 3,
      "name": "APIS check \u2014 valid check-in data",
      "description": "POST APIS (Advance Passenger Information) for a British passport holder on AX001 LHR\u2192JFK. Simulates the check-in submission pathway. The simulator always returns apisStatus: ACCEPTED with fineRisk: LOW and a generated audit reference in the format TMC-YYYY-MM-DD-XXXXXXXX.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/autocheck/v1/apischeck",
        "baseUrlRef": "timatic"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer timatic-test-2026"
        },
        "body": {
          "transactionIdentifier": "TXN-2026-APIS-001",
          "airlineCode": "AX",
          "flightNumber": "AX001",
          "departureDate": "__RAND_DEPART_DATE__",
          "departureAirport": "LHR",
          "arrivalAirport": "JFK",
          "paxInfo": {
            "surname": "__RAND_SURNAME__",
            "givenNames": "__RAND_GIVEN_NAME__",
            "dateOfBirth": "__RAND_DOB__",
            "gender": "__RAND_GENDER_CODE__",
            "nationality": "GBR",
            "documentType": "P",
            "documentNumber": "__RAND_DOC_NUMBER__",
            "documentIssuerCountry": "GBR",
            "documentExpiryDate": "__RAND_DOC_EXPIRY__"
          }
        }
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200
      },
      "chainsTo": []
    },
    {
      "step": 4,
      "name": "Realtime gate check \u2014 valid MRZ",
      "description": "POST a realtime gate check with a valid ICAO 9303 TD3 Machine Readable Passport MRZ generated from random pax data. The simulator parses the two MRZ lines and returns decision: GO with the extracted document fields in parsedDocument.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/autocheck/v1/realtimecheck",
        "baseUrlRef": "timatic"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer timatic-test-2026"
        },
        "body": {
          "transactionIdentifier": "TXN-2026-GATE-001",
          "airlineCode": "AX",
          "flightNumber": "AX001",
          "departureAirport": "LHR",
          "arrivalAirport": "JFK",
          "mrzData": {
            "line1": "__RAND_MRZ_LINE1__",
            "line2": "__RAND_MRZ_LINE2__"
          },
          "agentId": "AGENT-LHR-001",
          "checkTimestamp": "__RAND_DEPART_DATE__T06:30:00Z"
        }
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200
      },
      "chainsTo": []
    },
    {
      "step": 5,
      "name": "Document check \u2014 no Authorization header (401)",
      "description": "POST a document check without an Authorization header. The simulator rejects all requests that lack a Bearer token before reaching handler logic.",
