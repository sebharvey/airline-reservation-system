      "expected": {
        "statusCode": 401
      },
      "chainsTo": []
    },
    {
      "step": 6,
      "name": "APIS check \u2014 wrong bearer token (401)",
      "description": "POST an APIS check with a bearer token that does not match the configured Timatic:ApiToken. The SHA-256 hash comparison fails and the simulator returns 401 without processing the body.",
      "type": "negative",
      "apiCall": {
        "method": "POST",
        "endpoint": "/autocheck/v1/apischeck",
        "baseUrlRef": "timatic"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer this-is-the-wrong-token"
        },
        "body": {
          "transactionIdentifier": "TXN-2026-APIS-UNAUTH",
          "airlineCode": "AX",
          "flightNumber": "AX001",
          "departureDate": "__RAND_DEPART_DATE__",
          "departureAirport": "LHR",
          "arrivalAirport": "JFK",
          "paxInfo": {
            "surname": "__RAND_SURNAME__",
            "givenNames": "__RAND_GIVEN_NAME__",
            "dateOfBirth": "__RAND_DOB__",
            "gender": "__RAND_GENDER_CODE__",
