    {
      "step": 10,
      "name": "Realtime gate check — MRZ surname BLOCKED (decision: NO_GO)",
      "description": "POST a realtime gate check where MRZ line 1 encodes surname 'BLOCKED'. The simulator parses the MRZ, detects the sentinel surname, and returns decision: NO_GO with conditionsMet: false and carrierLiabilityConfirmed: false. Simulates a gate-level denial.",
      "type": "negative",
      "apiCall": {
        "method": "POST",
        "endpoint": "/autocheck/v1/realtimecheck",
