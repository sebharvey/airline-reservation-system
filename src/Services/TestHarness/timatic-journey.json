      "name": "Document check — FAIL document number (status: FAILED)",
      "description": "POST a document check where documentNumber starts with 'FAIL'. The simulator returns status: FAILED with visaRequired: true and a VISA requirement object. Simulates a rejected travel document.",
      "type": "negative",
      "apiCall": {
        "method": "POST",
        "endpoint": "/autocheck/v1/documentcheck",
        "baseUrlRef": "timatic"
