      "expected": {
        "statusCode": 401
      },
      "chainsTo": []
    },
    {
      "step": 7,
      "name": "Realtime check \u2014 malformed body (400)",
      "description": "POST a realtime check with a valid Authorization header but a malformed JSON body. The simulator returns 400 Bad Request when the body cannot be deserialized.",
      "type": "negative",
      "apiCall": {
        "method": "POST",
        "endpoint": "/autocheck/v1/realtimecheck",
        "baseUrlRef": "timatic",
        "note": "Body is intentionally null to trigger 400"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer timatic-test-2026"
        },
        "body": null
      },
      "response": {
        "statusCode": 400
      },
      "expected": {
        "statusCode": 400
      },
      "chainsTo": []
    },
    {
