{
  "journey": {
    "name": "Bookflow \u2014 Retail API",
    "description": "End-to-end booking journey via the Retail API: outbound flight search, return flight search, basket creation, passenger entry, seat selection, bag selection, and payment confirmation.",
    "domain": "Retail",
    "baseUrls": [
      {
        "id": "retail",
        "label": "Retail API",
        "url": "https://reservation-system-db-api-retail-aqasakbxcje0a6eh.uksouth-01.azurewebsites.net"
      }
    ]
  },
  "steps": [
    {
      "step": 1,
      "name": "Search outbound flights",
      "description": "Search for available outbound flights from LHR to JFK for a single adult passenger on a Revenue booking. Returns a sessionId and a list of flights with cabin and fare-family offers. The sessionId and a selected outbound offerId are forwarded to the basket creation step.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/search/slice",
        "baseUrlRef": "retail"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "origin": "LHR",
          "destination": "JFK",
          "departureDate": "__RAND_DEPART_DATE__",
          "paxCount": 1,
          "bookingType": "Revenue"
        }
      },
      "response": {
        "statusCode": 200,
        "body": {
