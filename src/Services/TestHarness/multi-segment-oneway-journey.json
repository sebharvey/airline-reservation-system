                "cabins": [
                  {
                    "cabinCode": "Y",
                    "availableSeats": 252,
                    "fromPrice": 186.25,
                    "currency": "GBP",
                    "fareFamilies": [
                      {
                        "fareFamily": "Flex",
                        "offer": {
                          "offerId": "a1b2c3d4-3333-3333-3333-000000000003",
                          "fareBasisCode": "YFLEXGB",
                          "basePrice": 249.0,
