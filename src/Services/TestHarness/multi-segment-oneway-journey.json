              },
              "leg2": {
                "sessionId": "a1b2c3d4-0002-0002-0002-000000000002",
                "flightNumber": "AX003",
                "origin": "LHR",
                "destination": "JFK",
                "departureDate": "2026-05-20",
                "departureTime": "10:30",
                "arrivalTime": "13:45",
