{
  "journey": {
    "name": "Admin \u2014 bag pricing",
    "description": "End-to-end journey covering bag pricing lifecycle management via the Operations API. Registers an employee account, authenticates via the Admin API to obtain a JWT, creates a bag pricing rule for sequence 1 in USD (avoiding conflict with seeded GBP rules), updates the price and sets a validity end date, verifies the saved changes by reading the record back, deletes the rule, then removes the employee account.",
    "domain": "Operations",
    "baseUrls": [
      {
        "id": "operations",
        "label": "Operations API",
        "url": "https://reservation-system-db-api-operations-gzfhekfvawaubkbs.uksouth-01.azurewebsites.net"
      },
      {
        "id": "admin",
        "label": "Admin API",
        "url": "https://reservation-system-db-api-admin-ageucwaad3axbxhm.uksouth-01.azurewebsites.net"
      },
      {
        "id": "user",
        "label": "User MS",
        "url": "https://reservation-system-db-microservice-user-frhedyd4dcc6aya8.uksouth-01.azurewebsites.net"
      }
    ]
  },
  "steps": [
    {
      "step": 1,
      "name": "Create employee account",
      "description": "Create a new Apex Air employee user account via the User MS using a randomly generated name, email, and username.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/users",
        "baseUrlRef": "user"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "username": "__RAND_GIVEN_NAME__.__RAND_SURNAME__",
          "email": "__RAND_EMAIL__",
          "password": "__RAND_PASSWORD__",
          "firstName": "__RAND_GIVEN_NAME__",
          "lastName": "__RAND_SURNAME__"
        }
      },
      "response": {
        "statusCode": 201
      },
      "expected": {
        "statusCode": 201
      },
      "chainsTo": [
        {
          "field": "userId",
          "usedInSteps": [
            8
          ]
        }
      ]
    },
    {
      "step": 2,
      "name": "Login \u2014 obtain access token",
      "description": "Authenticate the employee account created in Step 1 via the Admin API.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/auth/login",
        "baseUrlRef": "admin"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "username": "__RAND_GIVEN_NAME__.__RAND_SURNAME__",
          "password": "__RAND_PASSWORD__"
        },
        "dataChain": [
          {
            "field": "username",
            "source": "Step 1 \u2192 runtime-generated username"
          },
          {
            "field": "password",
            "source": "Step 1 \u2192 runtime-generated password"
          }
        ]
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200
      },
      "chainsTo": [
        {
          "field": "accessToken",
          "usedInSteps": [
            3,
            4,
            5,
            6,
            7
          ]
        }
      ]
    },
    {
      "step": 3,
      "name": "List all bag pricing rules",
      "description": "Retrieve all bag pricing rules via GET. Confirms the seeded GBP rules are present (sequences 1, 2, 99).",
      "type": "positive",
      "apiCall": {
        "method": "GET",
        "endpoint": "/api/v1/admin/bag-pricing",
        "baseUrlRef": "operations"
      },
      "request": {
        "headers": {},
        "body": null,
        "dataChain": [
          {
            "field": "Authorization",
            "from": "accessToken",
            "source": "Step 2 \u2192 accessToken (injected as Bearer token)"
          }
        ]
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200
      },
      "chainsTo": []
    },
    {
      "step": 4,
      "name": "Create bag pricing rule \u2014 sequence 1 USD",
      "description": "Create a new pricing rule for the 1st additional bag in USD at $55.00, valid from 2026-01-01 with no end date. USD is used to avoid conflicting with the seeded GBP rules.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/admin/bag-pricing",
        "baseUrlRef": "operations"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "bagSequence": 1,
          "currencyCode": "USD",
          "price": 55.0,
          "validFrom": "2026-01-01T00:00:00Z",
          "validTo": null
        },
        "dataChain": [
          {
            "field": "Authorization",
            "from": "accessToken",
            "source": "Step 2 \u2192 accessToken (injected as Bearer token)"
          }
        ]
      },
      "response": {
        "statusCode": 201
      },
      "expected": {
        "statusCode": 201
      },
      "chainsTo": [
        {
          "field": "pricingId",
          "usedInSteps": [
            5,
            6,
            7
          ]
        }
      ]
    },
    {
      "step": 5,
      "name": "Update bag pricing rule \u2014 increase price and set expiry",
      "description": "Update the pricing rule created in Step 4. Increase price from $55 to $65 and set a validity end date of 2026-12-31.",
      "type": "positive",
      "apiCall": {
        "method": "PUT",
        "endpoint": "/api/v1/admin/bag-pricing/{pricingId}",
        "baseUrlRef": "operations",
        "pathParams": {
          "pricingId": "from-step-4"
        }
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "price": 65.0,
          "isActive": true,
          "validFrom": "2026-01-01T00:00:00Z",
          "validTo": "2026-12-31T23:59:59Z"
        },
        "dataChain": [
          {
            "field": "Authorization",
            "from": "accessToken",
            "source": "Step 2 \u2192 accessToken (injected as Bearer token)"
          },
          {
            "field": "pricingId",
            "from": "pricingId",
            "source": "Step 4 \u2192 pricingId (injected into path)"
          }
        ],
        "diff": {
          "price": {
            "from": 55.0,
            "to": 65.0
          },
          "validTo": {
            "from": null,
            "to": "2026-12-31T23:59:59Z"
          }
        }
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200
      },
      "chainsTo": []
    },
    {
      "step": 6,
      "name": "Get bag pricing rule \u2014 verify save",
      "description": "Read the pricing rule back by its ID to confirm the update in Step 5 was durably saved.",
      "type": "positive",
      "apiCall": {
        "method": "GET",
        "endpoint": "/api/v1/admin/bag-pricing/{pricingId}",
        "baseUrlRef": "operations",
        "pathParams": {
          "pricingId": "from-step-4"
        }
      },
      "request": {
        "headers": {},
        "body": null,
        "dataChain": [
          {
            "field": "Authorization",
            "from": "accessToken",
            "source": "Step 2 \u2192 accessToken (injected as Bearer token)"
          },
          {
            "field": "pricingId",
            "from": "pricingId",
            "source": "Step 4 \u2192 pricingId (injected into path)"
          }
        ]
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200
      },
      "chainsTo": []
    },
    {
      "step": 7,
      "name": "Delete bag pricing rule",
      "description": "Permanently delete the pricing rule created in Step 4. Returns 204 No Content.",
      "type": "positive",
      "apiCall": {
        "method": "DELETE",
        "endpoint": "/api/v1/admin/bag-pricing/{pricingId}",
        "baseUrlRef": "operations",
        "pathParams": {
          "pricingId": "from-step-4"
        }
      },
      "request": {
        "headers": {},
        "body": null,
        "dataChain": [
          {
            "field": "Authorization",
            "from": "accessToken",
            "source": "Step 2 \u2192 accessToken (injected as Bearer token)"
          },
          {
            "field": "pricingId",
            "from": "pricingId",
            "source": "Step 4 \u2192 pricingId (injected into path)"
          }
        ]
      },
      "response": {
        "statusCode": 204
      },
      "expected": {
        "statusCode": 204
      },
      "chainsTo": []
    },
    {
      "step": 8,
      "name": "Delete employee account",
      "description": "Delete the employee account created in Step 1 to clean up test data.",
      "type": "positive",
      "apiCall": {
        "method": "DELETE",
        "endpoint": "/api/v1/users/{userId}",
        "baseUrlRef": "user",
        "pathParams": {
          "userId": "from-step-1"
        }
      },
      "request": {
        "headers": {},
        "body": null,
        "dataChain": [
          {
            "field": "userId",
            "from": "userId",
            "source": "Step 1 \u2192 userId (injected into path)"
          }
        ]
      },
      "response": {
        "statusCode": 204
      },
      "expected": {
        "statusCode": 204
      },
      "chainsTo": []
    }
  ]
}
