{
  "journey": {
    "name": "Admin \u2014 seat pricing",
    "description": "End-to-end journey covering seat pricing rule lifecycle management via the Retail API admin endpoints. Registers an employee account, authenticates via the Admin API to obtain a JWT, creates a seat pricing rule for Economy Window seats, reads it back by ID, updates the price and deactivates the rule, verifies the saved changes with a second read, deletes the rule, then removes the employee account.",
    "domain": "Retail",
    "baseUrls": [
      {
        "id": "retail",
        "label": "Retail API",
        "url": "https://reservation-system-db-api-retail-aqasakbxcje0a6eh.uksouth-01.azurewebsites.net"
      },
      {
        "id": "admin",
        "label": "Admin API",
        "url": "https://reservation-system-db-api-admin-ageucwaad3axbxhm.uksouth-01.azurewebsites.net"
      },
      {
        "id": "user",
        "label": "User MS",
        "url": "https://reservation-system-db-microservice-user-frhedyd4dcc6aya8.uksouth-01.azurewebsites.net"
      }
    ]
  },
  "steps": [
    {
      "step": 1,
      "name": "Create employee account",
      "description": "Create a new Apex Air employee user account via the User MS using a randomly generated name, email, and username. This account is used as the credential fixture for the Admin API login step that follows.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/users",
        "baseUrlRef": "user"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "username": "__RAND_GIVEN_NAME__.__RAND_SURNAME__",
          "email": "__RAND_EMAIL__",
          "password": "__RAND_PASSWORD__",
          "firstName": "__RAND_GIVEN_NAME__",
          "lastName": "__RAND_SURNAME__"
        }
      },
      "response": {
        "statusCode": 201
      },
      "expected": {
        "statusCode": 201
      },
      "chainsTo": [
        {
          "field": "userId",
          "usedInSteps": [
            8
          ]
        }
      ]
    },
    {
      "step": 2,
      "name": "Login \u2014 obtain access token",
      "description": "Authenticate the employee account created in Step 1 via the Admin API using the runtime-generated username and password. Validates that the Admin API orchestrates the User MS correctly and returns a signed JWT. The accessToken is carried forward as the Bearer credential for all Retail API admin calls in this journey.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/auth/login",
        "baseUrlRef": "admin"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "username": "__RAND_GIVEN_NAME__.__RAND_SURNAME__",
          "password": "__RAND_PASSWORD__"
        },
        "dataChain": [
          {
            "field": "username",
            "source": "Step 1 \u2192 runtime-generated username"
          },
          {
            "field": "password",
            "source": "Step 1 \u2192 runtime-generated password"
          }
        ]
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200
      },
      "chainsTo": [
        {
          "field": "accessToken",
          "usedInSteps": [
            3,
            4,
            5,
            6,
            7
          ]
        }
      ]
    },
    {
      "step": 3,
      "name": "Create seat pricing rule",
      "description": "Create a new Economy Window seat pricing rule (cabin Y, position Window, GBP 25.00) via the Retail API admin endpoint using the JWT from Step 2. The rule is active from 1 Jan 2026 with no expiry. The Retail API proxies the request through to the Ancillary microservice.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/admin/seat-pricing",
        "baseUrlRef": "retail"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "cabinCode": "Y",
          "seatPosition": "Window",
          "currencyCode": "GBP",
          "price": 25.0,
          "validFrom": "2026-01-01T00:00:00Z",
          "validTo": null
        },
        "dataChain": [
          {
            "field": "Authorization",
            "from": "accessToken",
            "source": "Step 2 \u2192 accessToken (injected as Bearer token)"
          }
        ]
      },
      "response": {
        "statusCode": 201
      },
      "expected": {
        "statusCode": 201
      },
      "chainsTo": [
        {
          "field": "seatPricingId",
          "usedInSteps": [
            4,
            5,
            6,
            7
          ]
        }
      ]
    },
    {
      "step": 4,
      "name": "Get seat pricing rule \u2014 verify creation",
      "description": "Read the seat pricing rule back by its ID using GET to independently confirm that Step 3 was durably saved. This step validates the Retail API GET-by-ID endpoint and confirms the Ancillary MS persisted all fields correctly.",
      "type": "positive",
      "apiCall": {
        "method": "GET",
        "endpoint": "/api/v1/admin/seat-pricing/{seatPricingId}",
        "baseUrlRef": "retail",
        "pathParams": {
          "seatPricingId": "from-step-3"
        }
      },
      "request": {
        "headers": {},
        "body": null,
        "dataChain": [
          {
            "field": "Authorization",
            "from": "accessToken",
            "source": "Step 2 \u2192 accessToken (injected as Bearer token)"
          },
          {
            "field": "seatPricingId",
            "from": "seatPricingId",
            "source": "Step 3 \u2192 seatPricingId (injected into path)"
          }
        ]
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200
      },
      "chainsTo": []
    },
    {
      "step": 5,
      "name": "Update seat pricing rule \u2014 revise price and deactivate",
      "description": "Update the seat pricing rule created in Step 3 via a full PUT using the JWT from Step 2. The price is increased from GBP 25.00 to GBP 30.00 and the rule is deactivated (isActive set to false) to simulate an end-of-season pricing suspension. All other fields are preserved.",
      "type": "positive",
      "apiCall": {
        "method": "PUT",
        "endpoint": "/api/v1/admin/seat-pricing/{seatPricingId}",
        "baseUrlRef": "retail",
        "pathParams": {
          "seatPricingId": "from-step-3"
        }
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "cabinCode": "Y",
          "seatPosition": "Window",
          "currencyCode": "GBP",
          "price": 30.0,
          "isActive": false,
          "validFrom": "2026-01-01T00:00:00Z",
          "validTo": "2026-12-31T23:59:59Z"
        },
        "dataChain": [
          {
            "field": "Authorization",
            "from": "accessToken",
            "source": "Step 2 \u2192 accessToken (injected as Bearer token)"
          },
          {
            "field": "seatPricingId",
            "from": "seatPricingId",
            "source": "Step 3 \u2192 seatPricingId (injected into path)"
          }
        ],
        "diff": {
          "price": {
            "from": 25.0,
            "to": 30.0
          },
          "isActive": {
            "from": true,
            "to": false
          },
          "validTo": {
            "from": null,
            "to": "2026-12-31T23:59:59Z"
          }
        }
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200
      },
      "chainsTo": []
    },
    {
      "step": 6,
      "name": "Get seat pricing rule \u2014 verify update",
      "description": "Read the seat pricing rule back by its ID to independently confirm that the update in Step 5 was durably saved. This step validates the revised price and deactivated status are correctly persisted in the Ancillary MS database.",
      "type": "positive",
      "apiCall": {
        "method": "GET",
        "endpoint": "/api/v1/admin/seat-pricing/{seatPricingId}",
        "baseUrlRef": "retail",
        "pathParams": {
          "seatPricingId": "from-step-3"
        }
      },
      "request": {
        "headers": {},
        "body": null,
        "dataChain": [
          {
            "field": "Authorization",
            "from": "accessToken",
            "source": "Step 2 \u2192 accessToken (injected as Bearer token)"
          },
          {
            "field": "seatPricingId",
            "from": "seatPricingId",
            "source": "Step 3 \u2192 seatPricingId (injected into path)"
          }
        ]
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200
      },
      "chainsTo": []
    },
    {
      "step": 7,
      "name": "Delete seat pricing rule",
      "description": "Permanently delete the seat pricing rule created in Step 3 using the JWT from Step 2. Confirms that the Retail API DELETE endpoint proxies to the Ancillary MS, removes the record, and returns 204 No Content. A subsequent GET for this seatPricingId would return 404.",
      "type": "positive",
      "apiCall": {
        "method": "DELETE",
        "endpoint": "/api/v1/admin/seat-pricing/{seatPricingId}",
        "baseUrlRef": "retail",
        "pathParams": {
          "seatPricingId": "from-step-3"
        }
      },
      "request": {
        "headers": {},
        "body": null,
        "dataChain": [
          {
            "field": "Authorization",
            "from": "accessToken",
            "source": "Step 2 \u2192 accessToken (injected as Bearer token)"
          },
          {
            "field": "seatPricingId",
            "from": "seatPricingId",
            "source": "Step 3 \u2192 seatPricingId (injected into path)"
          }
        ]
      },
      "response": {
        "statusCode": 204
      },
      "expected": {
        "statusCode": 204
      },
      "chainsTo": []
    },
    {
      "step": 8,
      "name": "Delete employee account",
      "description": "Delete the employee account created in Step 1 to clean up test data. Confirms that the User MS DELETE endpoint permanently removes the account and returns 204 No Content.",
      "type": "positive",
      "apiCall": {
        "method": "DELETE",
        "endpoint": "/api/v1/users/{userId}",
        "baseUrlRef": "user",
        "pathParams": {
          "userId": "from-step-1"
        }
      },
      "request": {
        "headers": {},
        "body": null,
        "dataChain": [
          {
            "field": "userId",
            "from": "userId",
            "source": "Step 1 \u2192 userId (injected into path)"
          }
        ]
      },
      "response": {
        "statusCode": 204
      },
      "expected": {
        "statusCode": 204
      },
      "chainsTo": []
    }
  ]
}
