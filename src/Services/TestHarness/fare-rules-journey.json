{
  "journey": {
    "name": "Admin \u2014 fare rules",
    "description": "End-to-end journey covering fare rule lifecycle management via the Operations API. Registers an employee account, authenticates via the Admin API to obtain a JWT, creates a fare rule with tax lines, updates the rule and tax lines, verifies the saved changes by reading the record back, deletes the fare rule, then removes the employee account.",
    "domain": "Operations",
    "baseUrls": [
      {
        "id": "operations",
        "label": "Operations API",
        "url": "https://reservation-system-db-api-operations-gzfhekfvawaubkbs.uksouth-01.azurewebsites.net"
      },
      {
        "id": "admin",
        "label": "Admin API",
        "url": "https://reservation-system-db-api-admin-ageucwaad3axbxhm.uksouth-01.azurewebsites.net"
      },
      {
        "id": "user",
        "label": "User MS",
        "url": "https://reservation-system-db-microservice-user-frhedyd4dcc6aya8.uksouth-01.azurewebsites.net"
      }
    ]
  },
  "steps": [
    {
      "step": 1,
      "name": "Create employee account",
      "description": "Create a new Apex Air employee user account via the User MS using a randomly generated name, email, and username. This account is used as the credential fixture for the Admin API login step that follows.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/users",
        "baseUrlRef": "user"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "username": "__RAND_GIVEN_NAME__.__RAND_SURNAME__",
          "email": "__RAND_EMAIL__",
          "password": "__RAND_PASSWORD__",
          "firstName": "__RAND_GIVEN_NAME__",
          "lastName": "__RAND_SURNAME__"
        }
      },
      "response": {
        "statusCode": 201
      },
      "expected": {
        "statusCode": 201
      },
      "chainsTo": [
        {
          "field": "userId",
          "usedInSteps": [
            7
          ]
        }
      ]
    },
    {
      "step": 2,
      "name": "Login \u2014 obtain access token",
      "description": "Authenticate the employee account created in Step 1 via the Admin API using the runtime-generated username and password. Validates that the Admin API orchestrates the User MS correctly and returns a signed JWT. The accessToken is carried forward as the Bearer credential for all Operations API calls in this journey.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/auth/login",
        "baseUrlRef": "admin"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "username": "__RAND_GIVEN_NAME__.__RAND_SURNAME__",
          "password": "__RAND_PASSWORD__"
        },
        "dataChain": [
          {
            "field": "username",
            "source": "Step 1 \u2192 runtime-generated username"
          },
          {
            "field": "password",
            "source": "Step 1 \u2192 runtime-generated password"
          }
        ]
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200
      },
      "chainsTo": [
        {
          "field": "accessToken",
          "usedInSteps": [
            3,
            4,
            5,
            6
          ]
        }
      ]
    },
    {
      "step": 3,
      "name": "Create fare rule",
      "description": "Create a new Economy Standard fare rule (cabin Y, fare basis YSTDGB) via the Operations API using the JWT from Step 2. The rule is a money-type rule with minimum and maximum amounts enabling continuous pricing. Two tax lines are included: UK Air Passenger Duty (GB, \u00a313) and a fuel surcharge (YQ, \u00a345).",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/admin/fare-rules",
        "baseUrlRef": "operations"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "ruleType": "Money",
          "flightNumber": null,
          "fareBasisCode": "YSTDGB",
          "fareFamily": "Economy Light",
          "cabinCode": "Y",
          "bookingClass": "Y",
          "currencyCode": "GBP",
          "minAmount": 150.0,
          "maxAmount": 350.0,
          "minPoints": null,
          "maxPoints": null,
          "pointsTaxes": null,
          "taxLines": [
            {
              "code": "GB",
              "amount": 13.0
            },
            {
              "code": "YQ",
              "amount": 45.0
            }
          ],
          "isRefundable": false,
          "isChangeable": false,
          "changeFeeAmount": 0.0,
          "cancellationFeeAmount": 0.0,
          "validFrom": "2026-01-01T00:00:00Z",
          "validTo": "2026-12-31T23:59:59Z"
        },
        "dataChain": [
          {
            "field": "Authorization",
            "from": "accessToken",
            "source": "Step 2 \u2192 accessToken (injected as Bearer token)"
          }
        ]
      },
      "response": {
        "statusCode": 201
      },
      "expected": {
        "statusCode": 201
      },
      "chainsTo": [
        {
          "field": "fareRuleId",
          "usedInSteps": [
            4,
            5,
            6
          ]
        }
      ]
    },
    {
      "step": 4,
      "name": "Edit fare rule and tax lines",
      "description": "Update the fare rule created in Step 3 via a full PUT using the JWT from Step 2. The fare family is promoted from 'Economy Light' to 'Economy Standard', the pricing band is widened (minAmount 150 \u2192 175, maxAmount 350 \u2192 400), and both tax line amounts are revised upward (GB APD 13 \u2192 15, YQ fuel surcharge 45 \u2192 50).",
      "type": "positive",
      "apiCall": {
        "method": "PUT",
        "endpoint": "/api/v1/admin/fare-rules/{fareRuleId}",
        "baseUrlRef": "operations",
        "pathParams": {
          "fareRuleId": "from-step-3"
        }
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "ruleType": "Money",
          "flightNumber": null,
          "fareBasisCode": "YSTDGB",
          "fareFamily": "Economy Standard",
          "cabinCode": "Y",
          "bookingClass": "Y",
          "currencyCode": "GBP",
          "minAmount": 175.0,
          "maxAmount": 400.0,
          "minPoints": null,
          "maxPoints": null,
          "pointsTaxes": null,
          "taxLines": [
            {
              "code": "GB",
              "amount": 15.0
            },
            {
              "code": "YQ",
              "amount": 50.0
            }
          ],
          "isRefundable": false,
          "isChangeable": false,
          "changeFeeAmount": 0.0,
          "cancellationFeeAmount": 0.0,
          "validFrom": "2026-01-01T00:00:00Z",
          "validTo": "2026-12-31T23:59:59Z"
        },
        "dataChain": [
          {
            "field": "Authorization",
            "from": "accessToken",
            "source": "Step 2 \u2192 accessToken (injected as Bearer token)"
          },
          {
            "field": "fareRuleId",
            "from": "fareRuleId",
            "source": "Step 3 \u2192 fareRuleId (injected into path)"
          }
        ],
        "diff": {
          "fareFamily": {
            "from": "Economy Light",
            "to": "Economy Standard"
          },
          "minAmount": {
            "from": 150.0,
            "to": 175.0
          },
          "maxAmount": {
            "from": 350.0,
            "to": 400.0
          },
          "taxLines[0].amount": {
            "from": 13.0,
            "to": 15.0
          },
          "taxLines[1].amount": {
            "from": 45.0,
            "to": 50.0
          }
        }
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200
      },
      "chainsTo": []
    },
    {
      "step": 5,
      "name": "Get fare rule \u2014 verify save",
      "description": "Read the fare rule back by its ID using GET to independently confirm the update in Step 4 was durably saved. This step validates that the database reflects the revised fareFamily, pricing band, and tax line amounts.",
      "type": "positive",
      "apiCall": {
        "method": "GET",
        "endpoint": "/api/v1/admin/fare-rules/{fareRuleId}",
        "baseUrlRef": "operations",
        "pathParams": {
          "fareRuleId": "from-step-3"
        }
      },
      "request": {
        "headers": {},
        "body": null,
        "dataChain": [
          {
            "field": "Authorization",
            "from": "accessToken",
            "source": "Step 2 \u2192 accessToken (injected as Bearer token)"
          },
          {
            "field": "fareRuleId",
            "from": "fareRuleId",
            "source": "Step 3 \u2192 fareRuleId (injected into path)"
          }
        ]
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200,
        "assertions": [
          {
            "field": "taxLines",
            "assertion": "count",
            "expected": 2
          }
        ]
      },
      "chainsTo": []
    },
    {
      "step": 6,
      "name": "Delete fare rule",
      "description": "Permanently delete the fare rule created in Step 3 using the JWT from Step 2. Confirms that the Operations API DELETE endpoint removes the record and returns 204 No Content. A subsequent GET for this fareRuleId would return 404.",
      "type": "positive",
      "apiCall": {
        "method": "DELETE",
        "endpoint": "/api/v1/admin/fare-rules/{fareRuleId}",
        "baseUrlRef": "operations",
        "pathParams": {
          "fareRuleId": "from-step-3"
        }
      },
      "request": {
        "headers": {},
        "body": null,
        "dataChain": [
          {
            "field": "Authorization",
            "from": "accessToken",
            "source": "Step 2 \u2192 accessToken (injected as Bearer token)"
          },
          {
            "field": "fareRuleId",
            "from": "fareRuleId",
            "source": "Step 3 \u2192 fareRuleId (injected into path)"
          }
        ]
      },
      "response": {
        "statusCode": 204
      },
      "expected": {
        "statusCode": 204
      },
      "chainsTo": []
    },
    {
      "step": 7,
      "name": "Delete employee account",
      "description": "Delete the employee account created in Step 1 to clean up test data. Confirms that the User MS DELETE endpoint permanently removes the account and returns 204 No Content.",
      "type": "positive",
      "apiCall": {
        "method": "DELETE",
        "endpoint": "/api/v1/users/{userId}",
        "baseUrlRef": "user",
        "pathParams": {
          "userId": "from-step-1"
        }
      },
      "request": {
        "headers": {},
        "body": null,
        "dataChain": [
          {
            "field": "userId",
            "from": "userId",
            "source": "Step 1 \u2192 userId (injected into path)"
          }
        ]
      },
      "response": {
        "statusCode": 204
      },
      "expected": {
        "statusCode": 204
      },
      "chainsTo": []
    }
  ]
}
