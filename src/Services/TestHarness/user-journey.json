{
  "journey": {
    "name": "User \u2014 account creation & authentication",
    "description": "End-to-end journey covering employee user creation, duplicate-username validation, listing all users, successful login with JWT issuance, and login failure with wrong credentials.",
    "domain": "User",
    "baseUrls": [
      {
        "id": "user",
        "label": "User MS",
        "url": "https://reservation-system-db-microservice-user-frhedyd4dcc6aya8.uksouth-01.azurewebsites.net"
      }
    ]
  },
  "steps": [
    {
      "step": 1,
      "name": "Add user",
      "description": "Create a new Apex Air employee user account with a randomly generated name, email, and username. Validates the full creation flow including password hashing and uniqueness checks.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/users",
        "baseUrlRef": "user"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "username": "__RAND_GIVEN_NAME__.__RAND_SURNAME__",
          "email": "__RAND_EMAIL__",
          "password": "__RAND_PASSWORD__",
          "firstName": "__RAND_GIVEN_NAME__",
          "lastName": "__RAND_SURNAME__"
        }
      },
      "response": {
        "statusCode": 201
      },
      "expected": {
        "statusCode": 201
      },
      "chainsTo": [
        {
          "field": "userId",
          "usedInSteps": [
            4,
            6
          ]
        }
      ]
    },
    {
      "step": 2,
      "name": "Duplicate username attempt",
      "description": "Attempt to create a second account using the same username generated in Step 1. Validates that the API correctly rejects the duplicate with a 409 Conflict response and does not modify the original account.",
      "type": "negative",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/users",
        "baseUrlRef": "user"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "username": "__RAND_GIVEN_NAME__.__RAND_SURNAME__",
          "email": "different.email@testmail.example.com",
          "password": "__RAND_PASSWORD__",
          "firstName": "__RAND_GIVEN_NAME__",
          "lastName": "__RAND_SURNAME__"
        },
        "dataChain": [
          {
            "field": "username",
            "source": "Step 1 \u2192 runtime-generated username"
          },
          {
            "field": "firstName",
            "source": "Step 1 \u2192 runtime-generated given name"
          },
          {
            "field": "lastName",
            "source": "Step 1 \u2192 runtime-generated surname"
          },
          {
            "field": "password",
            "source": "Step 1 \u2192 runtime-generated password"
          }
        ]
      },
      "response": {
        "statusCode": 409
      },
      "expected": {
        "statusCode": 409
      },
      "chainsTo": []
    },
    {
      "step": 3,
      "name": "Get all users",
      "description": "Retrieve the full list of employee user accounts. The account created in Step 1 must appear in the results. Confirms that passwordHash is never returned in list responses.",
      "type": "positive",
      "apiCall": {
        "method": "GET",
        "endpoint": "/api/v1/users",
        "baseUrlRef": "user"
      },
      "request": {
        "headers": {},
        "body": null
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200
      },
      "chainsTo": []
    },
    {
      "step": 4,
      "name": "Login \u2014 valid credentials",
      "description": "Authenticate the employee account created in Step 1 using the runtime-generated username and password. Validates JWT issuance, account state update (LastLoginAt, FailedLoginAttempts reset), and correct response shape.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/users/login",
        "baseUrlRef": "user"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "username": "__RAND_GIVEN_NAME__.__RAND_SURNAME__",
          "password": "__RAND_PASSWORD__"
        },
        "dataChain": [
          {
            "field": "username",
            "source": "Step 1 \u2192 runtime-generated username"
          },
          {
            "field": "password",
            "source": "Step 1 \u2192 runtime-generated password"
          }
        ]
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200
      },
      "chainsTo": [
        {
          "field": "accessToken",
          "usedInSteps": []
        },
        {
          "field": "userId",
          "usedInSteps": []
        }
      ]
    },
    {
      "step": 5,
      "name": "Login \u2014 wrong password",
      "description": "Attempt to authenticate using the correct username from Step 1 but an incorrect password. Validates that the API returns 401 Unauthorized and increments the FailedLoginAttempts counter on the account.",
      "type": "negative",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/users/login",
        "baseUrlRef": "user"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "username": "__RAND_GIVEN_NAME__.__RAND_SURNAME__",
          "password": "WrongPassword99!"
        },
        "dataChain": [
          {
            "field": "username",
            "source": "Step 1 \u2192 runtime-generated username"
          }
        ]
      },
      "response": {
        "statusCode": 401
      },
      "expected": {
        "statusCode": 401
      },
      "chainsTo": []
    },
    {
      "step": 6,
      "name": "Delete user",
      "description": "Delete the employee account created in Step 1 to clean up test data. Confirms that the DELETE endpoint permanently removes the account and returns 204 No Content.",
      "type": "positive",
      "apiCall": {
        "method": "DELETE",
        "endpoint": "/api/v1/users/{userId}",
        "baseUrlRef": "user",
        "pathParams": {
          "userId": "from-step-1"
        }
      },
      "request": {
        "headers": {},
        "body": null,
        "dataChain": [
          {
            "field": "userId",
            "source": "Step 1 \u2192 userId"
          }
        ]
      },
      "response": {
        "statusCode": 204
      },
      "expected": {
        "statusCode": 204
      },
      "chainsTo": []
    }
  ]
}
