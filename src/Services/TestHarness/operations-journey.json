{
  "journey": {
    "name": "Operations \u2014 SSIM import & inventory",
    "description": "End-to-end journey covering SSIM file import via the Operations API. The Operations API parses the SSIM file, converts each Type 3 scheduled-passenger leg to the season schedule JSON format, and forwards the full payload to the Schedule MS POST /v1/schedules, which atomically replaces all existing schedule records. Tests successful import, validation error handling, and empty-body rejection.",
    "domain": "Operations",
    "baseUrls": [
      {
        "id": "operations",
        "label": "Operations API",
        "url": "https://reservation-system-db-api-operations-gzfhekfvawaubkbs.uksouth-01.azurewebsites.net"
      }
    ]
  },
  "steps": [
    {
      "step": 1,
      "name": "Import SSIM \u2014 empty body",
      "description": "Submit a SSIM import request with an empty body. Validates that the Operations API rejects the request before attempting to parse or forward anything.",
      "type": "negative",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/schedules/ssim",
        "baseUrlRef": "operations"
      },
      "request": {
        "headers": {
          "Content-Type": "text/plain"
        },
        "body": ""
      },
      "response": {
        "statusCode": 400
      },
      "expected": {
        "statusCode": 400
      },
      "chainsTo": []
    },
    {
      "step": 2,
      "name": "Import SSIM \u2014 no valid Type 3 records",
      "description": "Submit a SSIM file that contains only header and trailer records (no Type 3 flight leg records). Validates that the Operations API returns 400 when the parsed record set is empty.",
      "type": "negative",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/schedules/ssim",
        "baseUrlRef": "operations"
      },
      "request": {
        "headers": {
          "Content-Type": "text/plain"
        },
        "body": "1IATA  AX              20260101 20261231AX  SCHED  20260326\n2AX  01W20260101 20261231\n5       0\n"
      },
      "response": {
        "statusCode": 400
      },
      "expected": {
        "statusCode": 400
      },
      "chainsTo": []
    },
    {
      "step": 3,
      "name": "Import SSIM \u2014 2026 season schedule (48 flights)",
      "description": "Import the full 2026 season SSIM file for Apex Air (48 scheduled-passenger flight legs, hub LHR, routes to JFK/LAX/MIA/SFO/ORD/BOS/BGI/KIN/NAS/HKG/NRT/PVG/PEK/SIN/BOM/DEL/BLR). The Operations API parses the SSIM file, builds the season schedule JSON payload, and forwards to Schedule MS which atomically replaces all existing schedule records.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/schedules/ssim?createdBy=ops-schedule-import",
        "baseUrlRef": "operations"
      },
      "request": {
        "headers": {
          "Content-Type": "text/plain"
        },
        "bodyFile": "res/schedules/flight-schedule-2026.ssim"
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200
      },
      "chainsTo": [
        {
          "field": "schedules[0].scheduleId",
          "usedInSteps": []
        }
      ]
    },
    {
      "step": 4,
      "name": "Re-import SSIM \u2014 confirms full replacement",
      "description": "Re-import the same 2026 season SSIM file. Validates that the Schedule MS atomically replaces all records: deleted count should equal the number previously imported (48), and imported count should again equal 48.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/schedules/ssim?createdBy=ops-schedule-reimport",
        "baseUrlRef": "operations"
      },
      "request": {
        "headers": {
          "Content-Type": "text/plain"
        },
        "bodyFile": "res/schedules/flight-schedule-2026.ssim"
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200
      },
      "chainsTo": []
    },
    {
      "step": 5,
      "name": "Import Inventory \u2014 empty cabins array",
      "description": "Submit an import-inventory request with an empty cabins array. Validates that the Operations API rejects the request before calling Schedule MS or Offer MS.",
      "type": "negative",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/schedules/import-inventory",
        "baseUrlRef": "operations"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "cabins": []
        }
      },
      "response": {
        "statusCode": 400
      },
      "expected": {
        "statusCode": 400
      },
      "chainsTo": []
    },
    {
      "step": 6,
      "name": "Import Inventory \u2014 cabin with no fares",
      "description": "Submit an import-inventory request where a cabin definition has an empty fares array. Validates that the Operations API rejects the request.",
      "type": "negative",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/schedules/import-inventory",
        "baseUrlRef": "operations"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "cabins": [
            {
              "cabinCode": "Y",
              "totalSeats": 180,
              "fares": []
            }
          ]
