          }
        }
      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK \u2014 basket retrieved. basketStatus is 'Active'. Both flight offers are present in basketData.flightOffers, each assigned a basketItemId (BI-1, BI-2). passengers, seats, and bags are empty arrays at this point. All amount totals are 0.00 until pricing is resolved.",
        "keyFields": [
          "basketId",
          "basketStatus",
          "basketData.flightOffers",
          "expiresAt"
        ],
        "validationNotes": "basketStatus must be 'Active'. confirmedOrderId is null until confirmed. version increments on each mutation. expiresAt is 60 minutes from creation."
      },
      "chainsTo": [
        {
          "path": "basketData.flightOffers[0].inventoryId",
          "as": "outboundInventoryId",
          "usedInSteps": [
            8
          ]
        },
        {
          "path": "basketData.flightOffers[0].flightNumber",
          "as": "outboundFlightNumber",
          "usedInSteps": [
            8
          ]
        },
        {
          "path": "basketData.flightOffers[0].aircraftType",
          "as": "outboundAircraftType",
          "usedInSteps": [
            8
          ]
        },
        {
          "path": "basketData.flightOffers[0].basketItemId",
          "as": "outboundBasketItemId",
          "usedInSteps": [
            10
          ]
        },
        {
          "path": "basketData.flightOffers[1].inventoryId",
          "as": "returnInventoryId",
          "usedInSteps": [
            9
          ]
        },
        {
          "path": "basketData.flightOffers[1].flightNumber",
          "as": "returnFlightNumber",
          "usedInSteps": [
            9
          ]
        },
        {
          "path": "basketData.flightOffers[1].aircraftType",
          "as": "returnAircraftType",
          "usedInSteps": [
            9
          ]
        },
        {
          "path": "basketData.flightOffers[1].basketItemId",
          "as": "returnBasketItemId",
          "usedInSteps": [
            10
          ]
        }
      ]
    },
    {
      "step": 6,
      "name": "Add passengers",
      "description": "Add passenger details to the basket. Each passenger record includes personal details, contact information, and an optional loyalty number for points accrual. The passengerId (PAX-1, PAX-2 \u2026) is assigned by the caller and must be consistent across seats and bags additions.",
      "type": "positive",
      "apiCall": {
        "method": "PUT",
        "endpoint": "/api/v1/basket/{basketId}/passengers",
        "baseUrlRef": "retail",
        "pathParams": {
          "basketId": "from-step-3"
        }
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": [
          {
            "passengerId": "PAX-1",
            "type": "ADT",
            "givenName": "__RAND_GIVEN_NAME__",
