{
  "journey": {
    "name": "OCI \u2014 2 pax outbound check-in",
    "description": "End-to-end journey combining booking and online check-in via the Retail and Operations APIs for 2 passengers: outbound and return flight search, basket creation, passenger entry, payment confirmation, passport submission, seat and bag selection, and boarding card generation.",
    "domain": "Retail / Operations",
    "baseUrls": [
      {
        "id": "retail",
        "label": "Retail API",
        "url": "https://reservation-system-db-api-retail-aqasakbxcje0a6eh.uksouth-01.azurewebsites.net"
      },
      {
        "id": "operations",
        "label": "Operations API",
        "url": "https://reservation-system-db-api-operations-gzfhekfvawaubkbs.uksouth-01.azurewebsites.net"
      }
    ]
  },
  "steps": [
    {
      "step": 1,
      "name": "Search outbound flights",
      "description": "Search for available outbound flights from LHR to JFK for a single adult passenger on a Revenue booking. Returns a sessionId and a list of flights with cabin and fare-family offers. The sessionId and a selected outbound offerId are forwarded to the basket creation step.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/search/slice",
        "baseUrlRef": "retail"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "origin": "LHR",
          "destination": "JFK",
          "departureDate": "__RAND_DEPART_DATE__",
          "paxCount": 2,
          "bookingType": "Revenue"
        }
      },
