            },
            "docs": []
          }
        ],
        "dataChain": [
          {
            "field": "basketId",
            "from": "basketId",
            "source": "Step 3 \u2192 response.basketId"
          }
        ]
      },
      "response": {
        "statusCode": 200,
        "body": {
          "basketId": "601255b6-9eed-465a-8ff4-c0e9c378155f",
          "status": "Active",
          "flights": [
            {
              "offerId": "bc2f449f-a828-4826-a97c-4378531d7253",
              "flightNumber": "",
              "origin": "",
              "destination": "",
              "cabinCode": "",
              "fareFamily": null,
              "totalAmount": 0
            },
            {
              "offerId": "19714659-fdbe-4593-9037-948ff69178ca",
              "flightNumber": "",
              "origin": "",
              "destination": "",
              "cabinCode": "",
              "fareFamily": null,
              "totalAmount": 0
            }
          ],
          "totalFareAmount": 0.0,
          "totalSeatAmount": 0.0,
          "totalBagAmount": 0.0,
          "totalPrice": 0.0,
          "currency": "GBP"
        }
      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK \u2014 passengers saved to the basket. Response is a basket summary. Passenger type must be a valid IATA code: ADT, CHD, INF, or YTH. contacts.email and contacts.phone are required for the primary passenger.",
        "keyFields": [
          "basketId",
          "status",
          "totalPrice"
        ],
        "validationNotes": "passengerId is caller-assigned (PAX-1, PAX-2) and must be referenced consistently in seats and bags. type uses IATA passenger type codes. docs is empty for domestic or when not yet collected."
      }
    },
    {
      "step": 7,
      "name": "Confirm and pay \u2014 valid card",
      "description": "Submit payment with a card number that passes the Luhn check to confirm the basket and create the order. The basket transitions to Confirmed and an orderId is returned.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/basket/{basketId}/confirm",
        "baseUrlRef": "retail",
        "pathParams": {
          "basketId": "from-step-3"
        }
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "payment": {
            "method": "CreditCard",
            "cardNumber": "4111111111111111",
            "expiryDate": "12/28",
            "cvv": "737",
            "cardholderName": "__RAND_GIVEN_NAME__ __RAND_SURNAME__"
          },
          "loyaltyPointsToRedeem": null
        },
        "dataChain": [
          {
            "field": "basketId",
            "from": "basketId",
            "source": "Step 3 \u2192 response.basketId"
          }
        ]
      },
      "response": {
        "statusCode": 201,
        "body": {
          "orderId": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
          "bookingReference": "AX123456",
          "status": "Confirmed",
          "eTickets": [
            {
              "passengerId": "PAX-1",
              "segmentIds": [
                "BI-1",
                "BI-2"
              ],
              "eTicketNumber": "932-0000000001"
            },
            {
              "passengerId": "PAX-2",
              "segmentIds": [
                "BI-1",
                "BI-2"
              ],
              "eTicketNumber": "932-0000000002"
            }
          ]
        }
      },
      "expected": {
        "statusCode": 201,
        "description": "201 Created \u2014 booking confirmed. The basket is marked Confirmed and a new order is created. The response contains the orderId (GUID) and the human-readable bookingReference used for check-in and manage-booking flows.",
        "keyFields": [
          "orderId",
          "bookingReference",
          "status",
          "eTickets"
        ],
        "validationNotes": "cardNumber 4111111111111111 is a standard Luhn-valid Visa test card number. payment.method valid values: CreditCard, DebitCard, PayPal, ApplePay. payment.cardNumber, payment.expiryDate, payment.cvv, and payment.cardholderName are required for card methods \u2014 passed directly to the Payment MS and never stored by the Retail API. loyaltyPointsToRedeem is null when paying by card only. On success, basketStatus on the basket resource transitions to Confirmed and confirmedOrderId is populated.",
        "assertions": [
          {
            "field": "eTickets",
            "assertion": "count",
            "expected": 2,
            "description": "Exactly two e-tickets must be issued \u2014 one per passenger."
          },
          {
            "field": "eTickets[*].eTicketNumber",
            "assertion": "present",
            "description": "Every e-ticket must carry a non-empty eTicketNumber in the format '932-NNNNNNNNNN'."
          }
        ]
      },
      "chainsTo": [
        {
          "field": "bookingReference",
