          { "field": "[5].basketItemRef","from": "basketItemId",     "source": "Step 4 → basketData.flightOffers[0].basketItemId" },
          { "field": "[5].seatOfferId",  "from": "seatOfferId_6",    "source": "Step 5 → seat 6 (PAX-6)" },
          { "field": "[5].seatNumber",   "from": "seatNumber_6",     "source": "Step 5 → seat 6 (PAX-6)" },
          { "field": "[5].seatPosition", "from": "seatPosition_6",   "source": "Step 5 → seat 6 (PAX-6)" },
          { "field": "[5].cabinCode",    "from": "seatCabinCode_6",  "source": "Step 5 → seat 6 (PAX-6)" },
          { "field": "[5].price",        "from": "seatPrice_6",      "source": "Step 5 → seat 6 (PAX-6)" },
          { "field": "[5].currency",     "from": "seatCurrency_6",   "source": "Step 5 → seat 6 (PAX-6)" }
        ]
      },
      "response": {
        "statusCode": 200,
        "body": {
          "basketId": "601255b6-9eed-465a-8ff4-c0e9c378155f",
          "status": "Active",
          "totalFareAmount": 0.00,
          "totalSeatAmount": 50.00,
          "totalBagAmount": 0.00,
          "totalPrice": 50.00,
          "currency": "GBP"
        }
      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK — seats saved to the basket for all passengers. totalSeatAmount reflects the sum of all selected seat prices.",
        "keyFields": ["basketId", "status", "totalSeatAmount", "totalPrice"],
        "validationNotes": "segmentId must be the inventoryId of the flight (not the offerId). Each passenger gets a distinct seat picked randomly from the seatmap. seatOfferId must match a valid available seat. cabinCode must match the booked cabin for the basket item. One seat per passenger per segment."
      }
    },
