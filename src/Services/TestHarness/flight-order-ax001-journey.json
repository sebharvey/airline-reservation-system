{
  "journey": {
    "name": "Flight Order — AX001 Next Day",
    "description": "Creates a confirmed one-way order for the next day's AX001 (LHR → JFK) flight. Covers outbound search, basket creation, passenger entry, seat selection, and payment confirmation.",
    "domain": "Retail",
    "baseUrls": [
      { "id": "retail", "label": "Retail API", "url": "https://reservation-system-db-api-retail-aqasakbxcje0a6eh.uksouth-01.azurewebsites.net" }
    ]
  },
  "steps": [
    {
      "step": 1,
      "name": "Search AX001 — next day",
      "description": "Search for available outbound flights from LHR to JFK on a future date. Expects AX001 in the results. The sessionId and a selected offerId are chained to the basket creation step.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/search/slice",
        "baseUrlRef": "retail"
      },
      "request": {
        "headers": { "Content-Type": "application/json" },
        "body": {
          "origin": "LHR",
          "destination": "JFK",
          "departureDate": "__RAND_DEPART_DATE__",
          "paxCount": "__RAND_PAX_COUNT__",
          "bookingType": "Revenue"
        }
      },
      "response": {
        "statusCode": 200,
        "body": {
          "sessionId": "518c85cc-8618-4a20-8874-235461e10e11",
          "flights": [
            {
              "flightNumber": "AX001",
              "origin": "LHR",
              "destination": "JFK",
              "departureTime": "2026-04-07T08:00:00",
              "arrivalTime": "2026-04-07T11:10:00",
              "aircraftType": "A351",
              "cabins": [
                {
                  "cabinCode": "Y",
                  "availableSeats": 252,
                  "fromPrice": 186.25,
                  "currency": "GBP",
                  "fareFamilies": [
                    { "fareFamily": "Non-Flex", "offer": { "offerId": "d8cf391f-67b2-4ab2-8b3b-423777f5156d", "fareBasisCode": "YLOWGB", "basePrice": 89.00, "tax": 97.25, "totalPrice": 186.25, "currency": "GBP", "isRefundable": false, "isChangeable": false } }
                  ]
                }
              ]
            }
          ]
        }
      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK — search results returned. AX001 appears in the flights array. sessionId and a selected offerId are chained to Step 2.",
        "keyFields": ["sessionId", "flights"],
        "validationNotes": "sessionId is a GUID scoped to this search. AX001 must be present in the flights array for 2026-04-07. A random available offer is selected from AX001's cabins and fare families only."
      },
      "chainsTo": [
        { "field": "sessionId", "as": "sessionId", "usedInSteps": [2] },
        { "randomArrayPath": "flights[?flightNumber=AX001].cabins[*].fareFamilies[*].offer.offerId", "as": "offerId", "usedInSteps": [2] }
      ]
    },
    {
      "step": 2,
      "name": "Create basket",
      "description": "Create a basket with the selected AX001 offer. Passes the sessionId from Step 1 alongside the offerId. Returns a basketId used for all subsequent basket operations.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/basket",
        "baseUrlRef": "retail"
      },
      "request": {
        "headers": { "Content-Type": "application/json" },
        "body": {
          "segments": [
            { "offerId": "d8cf391f-67b2-4ab2-8b3b-423777f5156d", "sessionId": "518c85cc-8618-4a20-8874-235461e10e11" }
          ],
          "channelCode": "WEB",
          "currencyCode": "GBP",
          "bookingType": "Revenue"
        },
        "dataChain": [
          { "field": "segments[0].offerId",   "from": "offerId",    "source": "Step 1 → random offer from search results" },
          { "field": "segments[0].sessionId", "from": "sessionId",  "source": "Step 1 → response.sessionId" }
        ]
      },
      "response": {
        "statusCode": 201,
        "body": {
          "basketId": "601255b6-9eed-465a-8ff4-c0e9c378155f"
        }
      },
      "expected": {
        "statusCode": 201,
        "description": "201 Created — basket created. Returns a basketId (GUID) used for all subsequent basket operations.",
        "keyFields": ["basketId"],
        "validationNotes": "basketId is a GUID. The single segment offerId must match a valid stored offer from the search session. The basket expires after 60 minutes of inactivity."
      },
      "chainsTo": [
        { "field": "basketId", "usedInSteps": [3, 4, 5, 6, 7] }
      ]
    },
    {
      "step": 3,
      "name": "Add passenger",
      "description": "Add a single adult passenger to the basket. Includes personal details and contact information required for ticketing.",
      "type": "positive",
      "apiCall": {
        "method": "PUT",
        "endpoint": "/api/v1/basket/{basketId}/passengers",
        "baseUrlRef": "retail",
        "pathParams": { "basketId": "from-step-2" }
      },
      "request": {
        "headers": { "Content-Type": "application/json" },
        "body": [
          { "__PAX_MIN__": 1, "passengerId": "PAX-1", "type": "ADT", "givenName": "__RAND_GIVEN_NAME__",   "surname": "__RAND_SURNAME__",   "dateOfBirth": "__RAND_DOB__",   "gender": "__RAND_GENDER__",   "loyaltyNumber": null, "contacts": { "email": "__RAND_EMAIL__",   "phone": "__RAND_PHONE__"   }, "travelDocument": null },
          { "__PAX_MIN__": 2, "passengerId": "PAX-2", "type": "ADT", "givenName": "__RAND_GIVEN_NAME_2__", "surname": "__RAND_SURNAME_2__", "dateOfBirth": "__RAND_DOB_2__", "gender": "__RAND_GENDER_2__", "loyaltyNumber": null, "contacts": { "email": "__RAND_EMAIL_2__", "phone": "__RAND_PHONE_2__" }, "travelDocument": null },
          { "__PAX_MIN__": 3, "passengerId": "PAX-3", "type": "ADT", "givenName": "__RAND_GIVEN_NAME_3__", "surname": "__RAND_SURNAME_3__", "dateOfBirth": "__RAND_DOB_3__", "gender": "__RAND_GENDER_3__", "loyaltyNumber": null, "contacts": { "email": "__RAND_EMAIL_3__", "phone": "__RAND_PHONE_3__" }, "travelDocument": null },
          { "__PAX_MIN__": 4, "passengerId": "PAX-4", "type": "ADT", "givenName": "__RAND_GIVEN_NAME_4__", "surname": "__RAND_SURNAME_4__", "dateOfBirth": "__RAND_DOB_4__", "gender": "__RAND_GENDER_4__", "loyaltyNumber": null, "contacts": { "email": "__RAND_EMAIL_4__", "phone": "__RAND_PHONE_4__" }, "travelDocument": null },
          { "__PAX_MIN__": 5, "passengerId": "PAX-5", "type": "ADT", "givenName": "__RAND_GIVEN_NAME_5__", "surname": "__RAND_SURNAME_5__", "dateOfBirth": "__RAND_DOB_5__", "gender": "__RAND_GENDER_5__", "loyaltyNumber": null, "contacts": { "email": "__RAND_EMAIL_5__", "phone": "__RAND_PHONE_5__" }, "travelDocument": null },
          { "__PAX_MIN__": 6, "passengerId": "PAX-6", "type": "ADT", "givenName": "__RAND_GIVEN_NAME_6__", "surname": "__RAND_SURNAME_6__", "dateOfBirth": "__RAND_DOB_6__", "gender": "__RAND_GENDER_6__", "loyaltyNumber": null, "contacts": { "email": "__RAND_EMAIL_6__", "phone": "__RAND_PHONE_6__" }, "travelDocument": null }
        ],
        "dataChain": [
          { "field": "basketId", "from": "basketId", "source": "Step 2 → response.basketId" }
        ]
      },
      "response": {
        "statusCode": 200,
        "body": {
          "basketId": "601255b6-9eed-465a-8ff4-c0e9c378155f",
          "status": "Active",
          "totalFareAmount": 0.00,
          "totalSeatAmount": 0.00,
          "totalBagAmount": 0.00,
          "totalPrice": 0.00,
          "currency": "GBP"
        }
      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK — PAX-1 saved to the basket. contacts.email and contacts.phone are required for the primary passenger.",
        "keyFields": ["basketId", "status"],
        "validationNotes": "One entry per passenger up to the random paxCount for this run (1–6). passengerIds PAX-1…PAX-N must be referenced consistently in seat selections. type uses IATA passenger type codes (ADT)."
      }
    },
    {
      "step": 4,
      "name": "Get basket — verify state",
      "description": "Retrieve the basket to confirm the passenger is saved and to extract the inventoryId, flightNumber, aircraftType, and basketItemId needed for the seatmap and seat selection steps.",
      "type": "positive",
      "apiCall": {
        "method": "GET",
        "endpoint": "/api/v1/basket/{basketId}",
        "baseUrlRef": "retail",
        "pathParams": { "basketId": "from-step-2" }
      },
      "request": {
        "headers": {},
        "dataChain": [
          { "field": "basketId", "from": "basketId", "source": "Step 2 → response.basketId" }
        ]
      },
      "response": {
        "statusCode": 200,
        "body": {
          "basketId": "601255b6-9eed-465a-8ff4-c0e9c378155f",
          "channelCode": "WEB",
          "currencyCode": "GBP",
          "basketStatus": "Active",
          "basketData": {
            "flightOffers": [
              {
                "offerId": "d8cf391f-67b2-4ab2-8b3b-423777f5156d",
                "basketItemId": "BI-1",
                "inventoryId": "806e766b-e87d-4153-9b69-bb2e7c4ee7f0",
                "flightNumber": "AX001",
                "aircraftType": "A351",
                "cabinCode": "Y"
              }
            ],
            "passengers": [
              {
                "passengerId": "PAX-1",
                "type": "ADT",
                "givenName": "__RAND_GIVEN_NAME__",
                "surname": "__RAND_SURNAME__"
              }
            ],
            "seats": [],
            "bags": []
          }
        }
      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK — basket retrieved. basketStatus is Active. PAX-1 is present in passengers. The single flightOffer carries the inventoryId, flightNumber, aircraftType, and basketItemId chained to subsequent steps.",
        "keyFields": ["basketStatus", "basketData.flightOffers", "basketData.passengers"],
        "validationNotes": "basketStatus must be Active. flightOffers must contain one entry for AX001. passengers must contain PAX-1."
      },
      "chainsTo": [
        { "path": "basketData.flightOffers[0].inventoryId",  "as": "inventoryId",  "usedInSteps": [5, 6] },
        { "path": "basketData.flightOffers[0].flightNumber", "as": "flightNumber", "usedInSteps": [5] },
        { "path": "basketData.flightOffers[0].aircraftType", "as": "aircraftType", "usedInSteps": [5] },
        { "path": "basketData.flightOffers[0].cabinCode",    "as": "cabinCode",    "usedInSteps": [5, 6] },
        { "path": "basketData.flightOffers[0].basketItemId", "as": "basketItemId", "usedInSteps": [6] }
      ]
    },
    {
      "step": 5,
      "name": "Get seatmap — AX001",
      "description": "Retrieve the seat map for AX001 using the inventoryId, flightNumber, aircraftType, and cabinCode chained from the basket. Passing cabinCode restricts the response to the booked cabin only. A random available seat from that cabin is selected and chained to the add-seat step.",
      "type": "positive",
      "apiCall": {
        "method": "GET",
        "endpoint": "/api/v1/flights/{inventoryId}/seatmap?aircraftType={aircraftType}&flightNumber={flightNumber}&cabinCode={cabinCode}",
        "baseUrlRef": "retail",
        "pathParams": {
          "inventoryId":   "from-step-4",
          "aircraftType":  "from-step-4",
          "flightNumber":  "from-step-4",
          "cabinCode":     "from-step-4"
        }
      },
      "request": {
        "headers": {},
        "dataChain": [
          { "field": "inventoryId",  "from": "inventoryId",  "source": "Step 4 → basketData.flightOffers[0].inventoryId" },
          { "field": "flightNumber", "from": "flightNumber", "source": "Step 4 → basketData.flightOffers[0].flightNumber" },
          { "field": "aircraftType", "from": "aircraftType", "source": "Step 4 → basketData.flightOffers[0].aircraftType" },
          { "field": "cabinCode",    "from": "cabinCode",    "source": "Step 4 → basketData.flightOffers[0].cabinCode" }
        ]
      },
      "response": {
        "statusCode": 200,
        "body": {
          "flightId": "806e766b-e87d-4153-9b69-bb2e7c4ee7f0",
          "flightNumber": "AX001",
          "aircraftType": "A351",
          "cabins": [
            {
              "cabinCode": "Y",
              "cabinName": "Economy",
              "columns": ["A","B","C","D","E","F","G","H","J","K"],
              "layout": "3-4-3",
              "startRow": 20,
              "endRow": 55,
              "seats": [
                { "seatOfferId": "so-20a-v1", "seatNumber": "20A", "column": "A", "rowNumber": 20, "position": "Window", "cabinCode": "Y", "price": 70, "currency": "GBP", "availability": "available", "attributes": [] },
                { "seatOfferId": "so-20c-v1", "seatNumber": "20C", "column": "C", "rowNumber": 20, "position": "Aisle",  "cabinCode": "Y", "price": 50, "currency": "GBP", "availability": "available", "attributes": [] }
              ]
            }
          ]
        }
      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK — seatmap returned for AX001 filtered to the booked cabin. A random available seat is picked and chained to Step 6.",
        "keyFields": ["flightId", "cabins"],
        "validationNotes": "The response contains only the booked cabin (cabinCode matches the offer). Only seats with availability 'available' can be selected. price reflects the surcharge for that seat position."
      },
      "chainsTo": [
        {
          "randomAvailableSeatFrom": "cabins",
          "as": {
            "seatOfferId": "seatOfferId",
            "seatNumber":  "seatNumber",
            "position":    "seatPosition",
            "cabinCode":   "seatCabinCode",
            "price":       "seatPrice",
            "currency":    "seatCurrency"
          },
          "usedInSteps": [6]
        }
      ]
    },
    {
      "step": 6,
      "name": "Add seat",
      "description": "Add the randomly selected seat to the basket for PAX-1 on the AX001 segment. Uses the inventoryId as segmentId and the basketItemId as basketItemRef, both chained from Step 4.",
      "type": "positive",
      "apiCall": {
        "method": "PUT",
        "endpoint": "/api/v1/basket/{basketId}/seats",
        "baseUrlRef": "retail",
        "pathParams": { "basketId": "from-step-2" }
      },
      "request": {
        "headers": { "Content-Type": "application/json" },
        "body": [
          { "__PAX_MIN__": 1, "passengerId": "PAX-1", "segmentId": "from-chain-inventoryId", "basketItemRef": "from-chain-basketItemId", "seatOfferId": "from-chain-seatOfferId_1", "seatNumber": "from-chain-seatNumber_1", "seatPosition": "from-chain-seatPosition_1", "cabinCode": "from-chain-seatCabinCode_1", "price": 0, "currency": "GBP" },
          { "__PAX_MIN__": 2, "passengerId": "PAX-2", "segmentId": "from-chain-inventoryId", "basketItemRef": "from-chain-basketItemId", "seatOfferId": "from-chain-seatOfferId_2", "seatNumber": "from-chain-seatNumber_2", "seatPosition": "from-chain-seatPosition_2", "cabinCode": "from-chain-seatCabinCode_2", "price": 0, "currency": "GBP" },
          { "__PAX_MIN__": 3, "passengerId": "PAX-3", "segmentId": "from-chain-inventoryId", "basketItemRef": "from-chain-basketItemId", "seatOfferId": "from-chain-seatOfferId_3", "seatNumber": "from-chain-seatNumber_3", "seatPosition": "from-chain-seatPosition_3", "cabinCode": "from-chain-seatCabinCode_3", "price": 0, "currency": "GBP" },
          { "__PAX_MIN__": 4, "passengerId": "PAX-4", "segmentId": "from-chain-inventoryId", "basketItemRef": "from-chain-basketItemId", "seatOfferId": "from-chain-seatOfferId_4", "seatNumber": "from-chain-seatNumber_4", "seatPosition": "from-chain-seatPosition_4", "cabinCode": "from-chain-seatCabinCode_4", "price": 0, "currency": "GBP" },
          { "__PAX_MIN__": 5, "passengerId": "PAX-5", "segmentId": "from-chain-inventoryId", "basketItemRef": "from-chain-basketItemId", "seatOfferId": "from-chain-seatOfferId_5", "seatNumber": "from-chain-seatNumber_5", "seatPosition": "from-chain-seatPosition_5", "cabinCode": "from-chain-seatCabinCode_5", "price": 0, "currency": "GBP" },
          { "__PAX_MIN__": 6, "passengerId": "PAX-6", "segmentId": "from-chain-inventoryId", "basketItemRef": "from-chain-basketItemId", "seatOfferId": "from-chain-seatOfferId_6", "seatNumber": "from-chain-seatNumber_6", "seatPosition": "from-chain-seatPosition_6", "cabinCode": "from-chain-seatCabinCode_6", "price": 0, "currency": "GBP" }
        ],
        "dataChain": [
          { "field": "[0].segmentId",    "from": "inventoryId",   "source": "Step 4 → basketData.flightOffers[0].inventoryId" },
          { "field": "[0].basketItemRef","from": "basketItemId",  "source": "Step 4 → basketData.flightOffers[0].basketItemId" },
          { "field": "[0].seatOfferId",  "from": "seatOfferId_1",    "source": "Step 5 → seat 1 (PAX-1)" },
          { "field": "[0].seatNumber",   "from": "seatNumber_1",     "source": "Step 5 → seat 1 (PAX-1)" },
          { "field": "[0].seatPosition", "from": "seatPosition_1",   "source": "Step 5 → seat 1 (PAX-1)" },
          { "field": "[0].cabinCode",    "from": "seatCabinCode_1",  "source": "Step 5 → seat 1 (PAX-1)" },
          { "field": "[0].price",        "from": "seatPrice_1",      "source": "Step 5 → seat 1 (PAX-1)" },
          { "field": "[0].currency",     "from": "seatCurrency_1",   "source": "Step 5 → seat 1 (PAX-1)" },
          { "field": "[1].segmentId",    "from": "inventoryId",      "source": "Step 4 → basketData.flightOffers[0].inventoryId" },
          { "field": "[1].basketItemRef","from": "basketItemId",     "source": "Step 4 → basketData.flightOffers[0].basketItemId" },
          { "field": "[1].seatOfferId",  "from": "seatOfferId_2",    "source": "Step 5 → seat 2 (PAX-2)" },
          { "field": "[1].seatNumber",   "from": "seatNumber_2",     "source": "Step 5 → seat 2 (PAX-2)" },
          { "field": "[1].seatPosition", "from": "seatPosition_2",   "source": "Step 5 → seat 2 (PAX-2)" },
          { "field": "[1].cabinCode",    "from": "seatCabinCode_2",  "source": "Step 5 → seat 2 (PAX-2)" },
          { "field": "[1].price",        "from": "seatPrice_2",      "source": "Step 5 → seat 2 (PAX-2)" },
          { "field": "[1].currency",     "from": "seatCurrency_2",   "source": "Step 5 → seat 2 (PAX-2)" },
          { "field": "[2].segmentId",    "from": "inventoryId",      "source": "Step 4 → basketData.flightOffers[0].inventoryId" },
          { "field": "[2].basketItemRef","from": "basketItemId",     "source": "Step 4 → basketData.flightOffers[0].basketItemId" },
          { "field": "[2].seatOfferId",  "from": "seatOfferId_3",    "source": "Step 5 → seat 3 (PAX-3)" },
          { "field": "[2].seatNumber",   "from": "seatNumber_3",     "source": "Step 5 → seat 3 (PAX-3)" },
          { "field": "[2].seatPosition", "from": "seatPosition_3",   "source": "Step 5 → seat 3 (PAX-3)" },
          { "field": "[2].cabinCode",    "from": "seatCabinCode_3",  "source": "Step 5 → seat 3 (PAX-3)" },
          { "field": "[2].price",        "from": "seatPrice_3",      "source": "Step 5 → seat 3 (PAX-3)" },
          { "field": "[2].currency",     "from": "seatCurrency_3",   "source": "Step 5 → seat 3 (PAX-3)" },
          { "field": "[3].segmentId",    "from": "inventoryId",      "source": "Step 4 → basketData.flightOffers[0].inventoryId" },
          { "field": "[3].basketItemRef","from": "basketItemId",     "source": "Step 4 → basketData.flightOffers[0].basketItemId" },
          { "field": "[3].seatOfferId",  "from": "seatOfferId_4",    "source": "Step 5 → seat 4 (PAX-4)" },
          { "field": "[3].seatNumber",   "from": "seatNumber_4",     "source": "Step 5 → seat 4 (PAX-4)" },
          { "field": "[3].seatPosition", "from": "seatPosition_4",   "source": "Step 5 → seat 4 (PAX-4)" },
          { "field": "[3].cabinCode",    "from": "seatCabinCode_4",  "source": "Step 5 → seat 4 (PAX-4)" },
          { "field": "[3].price",        "from": "seatPrice_4",      "source": "Step 5 → seat 4 (PAX-4)" },
          { "field": "[3].currency",     "from": "seatCurrency_4",   "source": "Step 5 → seat 4 (PAX-4)" },
          { "field": "[4].segmentId",    "from": "inventoryId",      "source": "Step 4 → basketData.flightOffers[0].inventoryId" },
          { "field": "[4].basketItemRef","from": "basketItemId",     "source": "Step 4 → basketData.flightOffers[0].basketItemId" },
          { "field": "[4].seatOfferId",  "from": "seatOfferId_5",    "source": "Step 5 → seat 5 (PAX-5)" },
          { "field": "[4].seatNumber",   "from": "seatNumber_5",     "source": "Step 5 → seat 5 (PAX-5)" },
