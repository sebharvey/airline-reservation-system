{
  "journey": {
    "name": "Bookflow \u2014 AX001 with seat selection",
    "description": "Creates a confirmed one-way order for the next day's AX001 (LHR \u2192 JFK) flight. Covers outbound search, basket creation, passenger entry, seat selection, and payment confirmation.",
    "domain": "Retail",
    "baseUrls": [
      {
        "id": "retail",
        "label": "Retail API",
        "url": "https://reservation-system-db-api-retail-aqasakbxcje0a6eh.uksouth-01.azurewebsites.net"
      }
    ]
  },
  "steps": [
    {
      "step": 1,
      "name": "Search AX001 \u2014 next day",
      "description": "Search for available outbound flights from LHR to JFK on a future date. Expects AX001 in the results. The sessionId and a selected offerId are chained to the basket creation step.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/search/slice",
        "baseUrlRef": "retail"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "origin": "LHR",
          "destination": "JFK",
          "departureDate": "__TOMORROW_DATE__",
          "paxCount": "__RAND_PAX_COUNT__",
          "bookingType": "Revenue"
        }
      },
      "response": {
        "statusCode": 200,
        "body": {
          "itineraries": [
            {
              "legs": [
                {
                  "sessionId": "518c85cc-8618-4a20-8874-235461e10e11",
                  "flightNumber": "AX001",
                  "origin": "LHR",
                  "destination": "JFK",
                  "departureDate": "2026-04-07",
                  "departureTime": "08:00",
                  "arrivalTime": "11:10",
                  "arrivalDayOffset": 0,
                  "aircraftType": "A351",
                  "cabins": [
                    {
                      "cabinCode": "Y",
                      "availableSeats": 252,
                      "fromPrice": 186.25,
                      "currency": "GBP",
                      "fareFamilies": [
                        {
                          "fareFamily": "Non-Flex",
                          "offer": {
                            "offerId": "d8cf391f-67b2-4ab2-8b3b-423777f5156d",
                            "fareBasisCode": "YLOWGB",
                            "basePrice": 89.0,
                            "tax": 97.25,
                            "totalPrice": 186.25,
                            "currency": "GBP",
                            "isRefundable": false,
                            "isChangeable": false
                          }
                        }
                      ]
                    }
                  ]
                }
              ],
              "connectionDurationMinutes": null,
              "combinedFromPrice": 186.25,
              "currency": "GBP"
            }
          ]
        }
      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK \u2014 search results returned. AX001 appears as the first leg in the itineraries list. The leg's sessionId and a selected offerId are chained to Step 2.",
        "keyFields": [
          "itineraries"
        ],
        "validationNotes": "AX001 must be present for the requested departure date. sessionId is nested in itineraries[0].legs[0]. A random available offer is selected across all cabin fare families."
      },
      "chainsTo": [
        {
          "path": "itineraries[0].legs[0].sessionId",
          "as": "sessionId",
          "usedInSteps": [
            2
          ]
        },
        {
          "randomArrayPath": "itineraries[*].legs[*].cabins[*].fareFamilies[*].offer.offerId",
          "as": "offerId",
          "usedInSteps": [
            2
          ]
        }
      ]
    },
    {
      "step": 2,
      "name": "Create basket",
      "description": "Create a basket with the selected AX001 offer. Passes the sessionId from Step 1 alongside the offerId. Returns a basketId used for all subsequent basket operations.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/basket",
        "baseUrlRef": "retail"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "segments": [
            {
              "offerId": "d8cf391f-67b2-4ab2-8b3b-423777f5156d",
              "sessionId": "518c85cc-8618-4a20-8874-235461e10e11"
            }
          ],
          "channelCode": "WEB",
          "currency": "GBP",
          "bookingType": "Revenue"
        },
        "dataChain": [
          {
            "field": "segments[0].offerId",
            "from": "offerId",
            "source": "Step 1 \u2192 random offer from search results"
          },
          {
            "field": "segments[0].sessionId",
            "from": "sessionId",
            "source": "Step 1 \u2192 response.sessionId"
          }
        ]
      },
      "response": {
        "statusCode": 201,
        "body": {
          "basketId": "601255b6-9eed-465a-8ff4-c0e9c378155f"
        }
      },
      "expected": {
        "statusCode": 201,
        "description": "201 Created \u2014 basket created. Returns a basketId (GUID) used for all subsequent basket operations.",
        "keyFields": [
          "basketId"
        ],
        "validationNotes": "basketId is a GUID. The single segment offerId must match a valid stored offer from the search session. The basket expires after 60 minutes of inactivity."
      },
      "chainsTo": [
        {
          "field": "basketId",
          "usedInSteps": [
            4,
            5,
            6,
            7,
            8
          ]
        }
      ]
    },
    {
      "step": 3,
      "name": "Get basket summary",
      "description": "Reprice all offers in the basket and retrieve a pricing summary with tax line breakdowns. This call triggers the Offer MS to refresh fare amounts from live cabin occupancy and FareRule data, copies tax lines into the stored offer, and sets validated = true on each inventory entry \u2014 unblocking the confirmation step.",
      "type": "positive",
      "apiCall": {
        "method": "GET",
        "endpoint": "/api/v1/basket/{basketId}/summary",
        "baseUrlRef": "retail",
        "pathParams": {
          "basketId": "from-step-2"
        }
      },
      "request": {
        "headers": {},
        "dataChain": [
          {
            "field": "basketId",
            "from": "basketId",
            "source": "Step 2 \u2192 response.basketId"
          }
        ]
      },
      "response": {
        "statusCode": 200,
        "body": {
          "basketId": "c0ffee00-1234-5678-abcd-000000000001",
          "status": "Active",
          "currency": "GBP",
          "flights": [
            {
              "validated": true,
              "taxLines": []
            }
          ]
        }
      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK \u2014 all offers repriced. Each flight entry has validated = true and taxLines populated from the FareRule.",
        "assertions": [
          {
            "field": "flights",
            "assertion": "present",
            "description": "flights array must be present and non-empty."
          },
          {
            "field": "flights[*].validated",
            "assertion": "equals",
            "expected": true,
            "description": "Every flight in the summary must have validated = true after repricing."
          }
        ]
      }
    },
