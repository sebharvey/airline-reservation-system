          { "field": "[4].cabinCode",    "from": "seatCabinCode_5",  "source": "Step 5 → seat 5 (PAX-5)" },
          { "field": "[4].price",        "from": "seatPrice_5",      "source": "Step 5 → seat 5 (PAX-5)" },
