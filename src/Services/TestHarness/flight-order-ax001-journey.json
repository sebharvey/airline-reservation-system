{
  "journey": {
    "name": "Flight Order — AX001 Next Day",
    "description": "Creates a confirmed one-way order for the next day's AX001 (LHR → JFK) flight. Covers outbound search, basket creation, passenger entry, seat selection, and payment confirmation.",
    "domain": "Retail",
    "baseUrls": [
      { "id": "retail", "label": "Retail API", "url": "https://reservation-system-db-api-retail-aqasakbxcje0a6eh.uksouth-01.azurewebsites.net" }
    ]
  },
  "steps": [
    {
      "step": 1,
      "name": "Search AX001 — next day",
      "description": "Search for available outbound flights from LHR to JFK on 2026-04-07 (next day). Expects AX001 in the results. The sessionId and a selected offerId are chained to the basket creation step.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/search/slice",
        "baseUrlRef": "retail"
      },
      "request": {
        "headers": { "Content-Type": "application/json" },
        "body": {
          "origin": "LHR",
          "destination": "JFK",
          "departureDate": "2026-04-07",
          "paxCount": 1,
          "bookingType": "Revenue"
        }
      },
      "response": {
        "statusCode": 200,
        "body": {
          "sessionId": "518c85cc-8618-4a20-8874-235461e10e11",
          "flights": [
            {
              "flightNumber": "AX001",
              "origin": "LHR",
              "destination": "JFK",
              "departureTime": "2026-04-07T08:00:00",
              "arrivalTime": "2026-04-07T11:10:00",
              "aircraftType": "A351",
              "cabins": [
                {
                  "cabinCode": "Y",
                  "availableSeats": 252,
                  "fromPrice": 186.25,
                  "currency": "GBP",
                  "fareFamilies": [
                    { "fareFamily": "Non-Flex", "offer": { "offerId": "d8cf391f-67b2-4ab2-8b3b-423777f5156d", "fareBasisCode": "YLOWGB", "basePrice": 89.00, "tax": 97.25, "totalPrice": 186.25, "currency": "GBP", "isRefundable": false, "isChangeable": false } }
                  ]
                }
              ]
            }
          ]
        }
      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK — search results returned. AX001 appears in the flights array. sessionId and a selected offerId are chained to Step 2.",
        "keyFields": ["sessionId", "flights"],
        "validationNotes": "sessionId is a GUID scoped to this search. AX001 must be present in the flights array for 2026-04-07. A random available offer is selected from AX001's cabins and fare families only."
      },
      "chainsTo": [
        { "field": "sessionId", "as": "sessionId", "usedInSteps": [2] },
        { "randomArrayPath": "flights[?flightNumber=AX001].cabins[*].fareFamilies[*].offer.offerId", "as": "offerId", "usedInSteps": [2] }
      ]
    },
    {
      "step": 2,
      "name": "Create basket",
      "description": "Create a basket with the selected AX001 offer. Passes the sessionId from Step 1 alongside the offerId. Returns a basketId used for all subsequent basket operations.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/basket",
        "baseUrlRef": "retail"
      },
      "request": {
        "headers": { "Content-Type": "application/json" },
        "body": {
          "segments": [
            { "offerId": "d8cf391f-67b2-4ab2-8b3b-423777f5156d", "sessionId": "518c85cc-8618-4a20-8874-235461e10e11" }
          ],
          "channelCode": "WEB",
          "currencyCode": "GBP",
          "bookingType": "Revenue"
        },
        "dataChain": [
          { "field": "segments[0].offerId",   "from": "offerId",    "source": "Step 1 → random offer from search results" },
          { "field": "segments[0].sessionId", "from": "sessionId",  "source": "Step 1 → response.sessionId" }
        ]
      },
      "response": {
        "statusCode": 201,
        "body": {
          "basketId": "601255b6-9eed-465a-8ff4-c0e9c378155f"
        }
      },
      "expected": {
        "statusCode": 201,
        "description": "201 Created — basket created. Returns a basketId (GUID) used for all subsequent basket operations.",
        "keyFields": ["basketId"],
        "validationNotes": "basketId is a GUID. The single segment offerId must match a valid stored offer from the search session. The basket expires after 60 minutes of inactivity."
      },
      "chainsTo": [
        { "field": "basketId", "usedInSteps": [3, 4, 5, 6, 7] }
      ]
    },
    {
      "step": 3,
      "name": "Add passenger",
      "description": "Add a single adult passenger to the basket. Includes personal details and contact information required for ticketing.",
      "type": "positive",
      "apiCall": {
        "method": "PUT",
        "endpoint": "/api/v1/basket/{basketId}/passengers",
        "baseUrlRef": "retail",
        "pathParams": { "basketId": "from-step-2" }
      },
      "request": {
        "headers": { "Content-Type": "application/json" },
        "body": [
          {
            "passengerId": "PAX-1",
            "type": "ADT",
            "givenName": "__RAND_GIVEN_NAME__",
            "surname": "__RAND_SURNAME__",
            "dateOfBirth": "__RAND_DOB__",
            "gender": "__RAND_GENDER__",
            "loyaltyNumber": null,
            "contacts": {
              "email": "__RAND_EMAIL__",
              "phone": "__RAND_PHONE__"
            },
            "travelDocument": null
          }
        ],
        "dataChain": [
          { "field": "basketId", "from": "basketId", "source": "Step 2 → response.basketId" }
        ]
      },
      "response": {
        "statusCode": 200,
        "body": {
          "basketId": "601255b6-9eed-465a-8ff4-c0e9c378155f",
          "status": "Active",
          "totalFareAmount": 0.00,
          "totalSeatAmount": 0.00,
          "totalBagAmount": 0.00,
          "totalPrice": 0.00,
          "currency": "GBP"
        }
      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK — PAX-1 saved to the basket. contacts.email and contacts.phone are required for the primary passenger.",
        "keyFields": ["basketId", "status"],
        "validationNotes": "passengerId PAX-1 must be referenced consistently in seat selections. type uses IATA passenger type codes (ADT)."
      }
    },
    {
      "step": 4,
      "name": "Get basket — verify state",
      "description": "Retrieve the basket to confirm the passenger is saved and to extract the inventoryId, flightNumber, aircraftType, and basketItemId needed for the seatmap and seat selection steps.",
      "type": "positive",
      "apiCall": {
        "method": "GET",
        "endpoint": "/api/v1/basket/{basketId}",
        "baseUrlRef": "retail",
        "pathParams": { "basketId": "from-step-2" }
      },
      "request": {
        "headers": {},
        "dataChain": [
          { "field": "basketId", "from": "basketId", "source": "Step 2 → response.basketId" }
        ]
      },
      "response": {
        "statusCode": 200,
        "body": {
          "basketId": "601255b6-9eed-465a-8ff4-c0e9c378155f",
          "channelCode": "WEB",
          "currencyCode": "GBP",
          "basketStatus": "Active",
          "basketData": {
            "flightOffers": [
              {
                "offerId": "d8cf391f-67b2-4ab2-8b3b-423777f5156d",
                "basketItemId": "BI-1",
                "inventoryId": "806e766b-e87d-4153-9b69-bb2e7c4ee7f0",
                "flightNumber": "AX001",
                "aircraftType": "A351"
              }
            ],
            "passengers": [
              {
                "passengerId": "PAX-1",
                "type": "ADT",
                "givenName": "__RAND_GIVEN_NAME__",
                "surname": "__RAND_SURNAME__"
              }
            ],
            "seats": [],
            "bags": []
          }
        }
      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK — basket retrieved. basketStatus is Active. PAX-1 is present in passengers. The single flightOffer carries the inventoryId, flightNumber, aircraftType, and basketItemId chained to subsequent steps.",
        "keyFields": ["basketStatus", "basketData.flightOffers", "basketData.passengers"],
        "validationNotes": "basketStatus must be Active. flightOffers must contain one entry for AX001. passengers must contain PAX-1."
      },
      "chainsTo": [
        { "path": "basketData.flightOffers[0].inventoryId",  "as": "inventoryId",  "usedInSteps": [5, 6] },
        { "path": "basketData.flightOffers[0].flightNumber", "as": "flightNumber", "usedInSteps": [5] },
        { "path": "basketData.flightOffers[0].aircraftType", "as": "aircraftType", "usedInSteps": [5] },
        { "path": "basketData.flightOffers[0].basketItemId", "as": "basketItemId", "usedInSteps": [6] }
      ]
    },
    {
      "step": 5,
      "name": "Get seatmap — AX001",
      "description": "Retrieve the seat map for AX001 using the inventoryId, flightNumber, and aircraftType chained from the basket. A random available seat is selected and chained to the add-seat step.",
      "type": "positive",
      "apiCall": {
        "method": "GET",
        "endpoint": "/api/v1/flights/{inventoryId}/seatmap?aircraftType={aircraftType}&flightNumber={flightNumber}",
        "baseUrlRef": "retail",
        "pathParams": {
          "inventoryId":   "from-step-4",
          "aircraftType":  "from-step-4",
          "flightNumber":  "from-step-4"
        }
      },
      "request": {
        "headers": {},
        "dataChain": [
          { "field": "inventoryId",  "from": "inventoryId",  "source": "Step 4 → basketData.flightOffers[0].inventoryId" },
          { "field": "flightNumber", "from": "flightNumber", "source": "Step 4 → basketData.flightOffers[0].flightNumber" },
          { "field": "aircraftType", "from": "aircraftType", "source": "Step 4 → basketData.flightOffers[0].aircraftType" }
        ]
      },
      "response": {
        "statusCode": 200,
        "body": {
          "flightId": "806e766b-e87d-4153-9b69-bb2e7c4ee7f0",
          "flightNumber": "AX001",
          "aircraftType": "A351",
          "cabins": [
            {
              "cabinCode": "Y",
              "cabinName": "Economy",
              "columns": ["A","B","C","D","E","F","G","H","J","K"],
              "layout": "3-4-3",
              "startRow": 20,
              "endRow": 55,
              "seats": [
                { "seatOfferId": "so-20a-v1", "seatNumber": "20A", "column": "A", "rowNumber": 20, "position": "Window", "cabinCode": "Y", "price": 70, "currency": "GBP", "availability": "available", "attributes": [] },
                { "seatOfferId": "so-20c-v1", "seatNumber": "20C", "column": "C", "rowNumber": 20, "position": "Aisle",  "cabinCode": "Y", "price": 50, "currency": "GBP", "availability": "available", "attributes": [] }
              ]
            }
          ]
        }
      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK — seatmap returned for AX001. A random available seat is picked and chained to Step 6.",
        "keyFields": ["flightId", "cabins"],
        "validationNotes": "Only seats with availability 'available' can be selected. price reflects the surcharge for that seat position."
      },
      "chainsTo": [
        {
          "randomAvailableSeatFrom": "cabins",
          "as": {
            "seatOfferId": "seatOfferId",
            "seatNumber":  "seatNumber",
            "position":    "seatPosition",
            "price":       "seatPrice",
            "currency":    "seatCurrency"
          },
          "usedInSteps": [6]
        }
      ]
    },
    {
      "step": 6,
      "name": "Add seat",
      "description": "Add the randomly selected seat to the basket for PAX-1 on the AX001 segment. Uses the inventoryId as segmentId and the basketItemId as basketItemRef, both chained from Step 4.",
      "type": "positive",
      "apiCall": {
        "method": "PUT",
        "endpoint": "/api/v1/basket/{basketId}/seats",
        "baseUrlRef": "retail",
        "pathParams": { "basketId": "from-step-2" }
      },
      "request": {
        "headers": { "Content-Type": "application/json" },
        "body": [
          {
            "passengerId": "PAX-1",
            "segmentId":    "from-chain-inventoryId",
            "basketItemRef": "from-chain-basketItemId",
            "seatOfferId":  "from-chain-seatOfferId",
            "seatNumber":   "from-chain-seatNumber",
            "seatPosition": "from-chain-seatPosition",
            "price":        0,
            "currency":     "GBP"
          }
        ],
        "dataChain": [
          { "field": "[0].segmentId",    "from": "inventoryId",  "source": "Step 4 → basketData.flightOffers[0].inventoryId" },
          { "field": "[0].basketItemRef","from": "basketItemId", "source": "Step 4 → basketData.flightOffers[0].basketItemId" },
          { "field": "[0].seatOfferId",  "from": "seatOfferId",  "source": "Step 5 → random available seat" },
          { "field": "[0].seatNumber",   "from": "seatNumber",   "source": "Step 5 → random available seat" },
          { "field": "[0].seatPosition", "from": "seatPosition", "source": "Step 5 → random available seat" },
          { "field": "[0].price",        "from": "seatPrice",    "source": "Step 5 → random available seat" },
          { "field": "[0].currency",     "from": "seatCurrency", "source": "Step 5 → random available seat" }
        ]
      },
      "response": {
        "statusCode": 200,
        "body": {
          "basketId": "601255b6-9eed-465a-8ff4-c0e9c378155f",
          "status": "Active",
          "totalFareAmount": 0.00,
          "totalSeatAmount": 50.00,
          "totalBagAmount": 0.00,
          "totalPrice": 50.00,
          "currency": "GBP"
        }
      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK — seat saved to the basket for PAX-1. totalSeatAmount reflects the selected seat's price.",
        "keyFields": ["basketId", "status", "totalSeatAmount", "totalPrice"],
        "validationNotes": "segmentId must be the inventoryId of the flight (not the offerId). seatOfferId must match a valid available seat from the seatmap. One seat per passenger per segment."
      }
    },
    {
      "step": 7,
      "name": "Confirm and pay",
      "description": "Submit payment with a Luhn-valid test card to confirm the basket and create the order. The basket transitions to Confirmed and an orderId and bookingReference are returned.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/basket/{basketId}/confirm",
        "baseUrlRef": "retail",
        "pathParams": { "basketId": "from-step-2" }
      },
      "request": {
        "headers": { "Content-Type": "application/json" },
        "body": {
          "payment": {
            "method": "CreditCard",
            "cardNumber": "4111111111111111",
            "expiryDate": "12/28",
            "cvv": "737",
            "cardholderName": "__RAND_GIVEN_NAME__ __RAND_SURNAME__"
          },
          "loyaltyPointsToRedeem": null
        },
        "dataChain": [
          { "field": "basketId", "from": "basketId", "source": "Step 2 → response.basketId" }
        ]
      },
      "response": {
        "statusCode": 201,
        "body": {
          "orderId": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
          "bookingReference": "AX123456",
          "status": "Confirmed"
        }
      },
      "expected": {
        "statusCode": 201,
        "description": "201 Created — order created for AX001 on 2026-04-07. The basket is marked Confirmed and the response contains the orderId (GUID) and the human-readable bookingReference.",
        "keyFields": ["orderId", "bookingReference", "status"],
        "validationNotes": "cardNumber 4111111111111111 is a standard Luhn-valid Visa test card. On success, basketStatus transitions to Confirmed and confirmedOrderId is populated on the basket resource. loyaltyPointsToRedeem is null for a standard card payment."
      },
      "chainsTo": [
        { "field": "orderId",           "as": "orderId",           "usedInSteps": [] },
        { "field": "bookingReference",  "as": "bookingReference",  "usedInSteps": [] }
      ]
    }
  ]
}
