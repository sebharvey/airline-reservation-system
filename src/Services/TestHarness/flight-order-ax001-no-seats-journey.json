{
  "journey": {
    "name": "Bookflow \u2014 AX001 without seats",
    "description": "Creates a confirmed one-way order for the next day's AX001 (LHR \u2192 JFK) flight without seat selection. Covers outbound search, basket creation, passenger entry, and payment confirmation.",
    "domain": "Retail",
    "baseUrls": [
      {
        "id": "retail",
        "label": "Retail API",
        "url": "https://reservation-system-db-api-retail-aqasakbxcje0a6eh.uksouth-01.azurewebsites.net"
      }
    ]
  },
  "steps": [
    {
      "step": 1,
      "name": "Search AX001 \u2014 next day",
      "description": "Search for available outbound flights from LHR to JFK on a future date. Expects AX001 in the results. The sessionId and a selected offerId are chained to the basket creation step.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/search/slice",
        "baseUrlRef": "retail"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "origin": "LHR",
          "destination": "JFK",
          "departureDate": "__TOMORROW_DATE__",
          "paxCount": "__RAND_PAX_COUNT__",
          "bookingType": "Revenue"
        }
      },
      "response": {
        "statusCode": 200,
        "body": {
          "itineraries": [
            {
              "legs": [
                {
                  "sessionId": "518c85cc-8618-4a20-8874-235461e10e11",
                  "flightNumber": "AX001",
                  "origin": "LHR",
                  "destination": "JFK",
                  "departureDate": "2026-04-07",
                  "departureTime": "08:00",
                  "arrivalTime": "11:10",
                  "arrivalDayOffset": 0,
                  "aircraftType": "A351",
                  "cabins": [
                    {
                      "cabinCode": "Y",
                      "availableSeats": 252,
                      "fromPrice": 186.25,
                      "currency": "GBP",
                      "fareFamilies": [
                        {
                          "fareFamily": "Non-Flex",
                          "offer": {
                            "offerId": "d8cf391f-67b2-4ab2-8b3b-423777f5156d",
                            "fareBasisCode": "YLOWGB",
                            "basePrice": 89.0,
                            "tax": 97.25,
                            "totalPrice": 186.25,
                            "currency": "GBP",
                            "isRefundable": false,
                            "isChangeable": false
                          }
                        }
                      ]
                    }
                  ]
                }
              ],
              "connectionDurationMinutes": null,
              "combinedFromPrice": 186.25,
              "currency": "GBP"
            }
          ]
        }
      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK \u2014 search results returned. AX001 appears as the first leg in the itineraries list. The leg's sessionId and a selected offerId are chained to Step 2.",
        "keyFields": [
          "itineraries"
        ],
        "validationNotes": "AX001 must be present for the requested departure date. sessionId is nested in itineraries[0].legs[0]. A random available offer is selected across all cabin fare families."
      },
      "chainsTo": [
        {
          "path": "itineraries[0].legs[0].sessionId",
          "as": "sessionId",
          "usedInSteps": [
            2
          ]
        },
        {
          "randomArrayPath": "itineraries[*].legs[*].cabins[*].fareFamilies[*].offer.offerId",
          "as": "offerId",
          "usedInSteps": [
            2
          ]
        }
      ]
    },
    {
      "step": 2,
      "name": "Create basket",
      "description": "Create a basket with the selected AX001 offer. Passes the sessionId from Step 1 alongside the offerId. Returns a basketId used for all subsequent basket operations.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/basket",
        "baseUrlRef": "retail"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "segments": [
            {
              "offerId": "d8cf391f-67b2-4ab2-8b3b-423777f5156d",
              "sessionId": "518c85cc-8618-4a20-8874-235461e10e11"
            }
          ],
          "channelCode": "WEB",
          "currency": "GBP",
          "bookingType": "Revenue"
        },
        "dataChain": [
          {
            "field": "segments[0].offerId",
            "from": "offerId",
            "source": "Step 1 \u2192 random offer from search results"
          },
          {
            "field": "segments[0].sessionId",
            "from": "sessionId",
            "source": "Step 1 \u2192 response.sessionId"
          }
        ]
      },
      "response": {
        "statusCode": 201,
        "body": {
          "basketId": "601255b6-9eed-465a-8ff4-c0e9c378155f"
        }
      },
      "expected": {
        "statusCode": 201,
        "description": "201 Created \u2014 basket created. Returns a basketId (GUID) used for all subsequent basket operations.",
        "keyFields": [
          "basketId"
        ],
        "validationNotes": "basketId is a GUID. The single segment offerId must match a valid stored offer from the search session. The basket expires after 60 minutes of inactivity."
      },
      "chainsTo": [
        {
          "field": "basketId",
          "usedInSteps": [
            4,
            5,
            6
          ]
        }
      ]
    },
    {
      "step": 3,
      "name": "Get basket summary",
      "description": "Reprice all offers in the basket and retrieve a pricing summary with tax line breakdowns. This call triggers the Offer MS to refresh fare amounts from live cabin occupancy and FareRule data, copies tax lines into the stored offer, and sets validated = true on each inventory entry \u2014 unblocking the confirmation step.",
      "type": "positive",
      "apiCall": {
        "method": "GET",
        "endpoint": "/api/v1/basket/{basketId}/summary",
        "baseUrlRef": "retail",
        "pathParams": {
          "basketId": "from-step-2"
        }
      },
      "request": {
        "headers": {},
        "dataChain": [
          {
            "field": "basketId",
            "from": "basketId",
            "source": "Step 2 \u2192 response.basketId"
          }
        ]
      },
      "response": {
        "statusCode": 200,
        "body": {
          "basketId": "c0ffee00-1234-5678-abcd-000000000001",
          "status": "Active",
          "currency": "GBP",
          "flights": [
            {
              "validated": true,
              "taxLines": []
            }
          ]
        }
      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK \u2014 all offers repriced. Each flight entry has validated = true and taxLines populated from the FareRule.",
        "assertions": [
          {
            "field": "flights",
            "assertion": "present",
            "description": "flights array must be present and non-empty."
          },
          {
            "field": "flights[*].validated",
            "assertion": "equals",
            "expected": true,
            "description": "Every flight in the summary must have validated = true after repricing."
          }
        ]
      }
    },
    {
      "step": 4,
      "name": "Add passenger",
      "description": "Add a single adult passenger to the basket. Includes personal details and contact information required for ticketing.",
      "type": "positive",
      "apiCall": {
        "method": "PUT",
        "endpoint": "/api/v1/basket/{basketId}/passengers",
        "baseUrlRef": "retail",
        "pathParams": {
          "basketId": "from-step-2"
        }
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": [
          {
            "__PAX_MIN__": 1,
            "passengerId": "PAX-1",
            "type": "ADT",
            "givenName": "__RAND_GIVEN_NAME__",
            "surname": "__RAND_SURNAME__",
            "dob": "__RAND_DOB__",
            "gender": "__RAND_GENDER__",
            "loyaltyNumber": null,
            "contacts": {
              "email": "__RAND_EMAIL__",
              "phone": "__RAND_PHONE__"
            },
            "docs": []
          },
          {
            "__PAX_MIN__": 2,
            "passengerId": "PAX-2",
            "type": "ADT",
            "givenName": "__RAND_GIVEN_NAME_2__",
            "surname": "__RAND_SURNAME_2__",
            "dob": "__RAND_DOB_2__",
            "gender": "__RAND_GENDER_2__",
            "loyaltyNumber": null,
            "contacts": {
              "email": "__RAND_EMAIL_2__",
              "phone": "__RAND_PHONE_2__"
            },
            "docs": []
          },
          {
            "__PAX_MIN__": 3,
            "passengerId": "PAX-3",
            "type": "ADT",
            "givenName": "__RAND_GIVEN_NAME_3__",
            "surname": "__RAND_SURNAME_3__",
            "dob": "__RAND_DOB_3__",
            "gender": "__RAND_GENDER_3__",
            "loyaltyNumber": null,
            "contacts": {
              "email": "__RAND_EMAIL_3__",
              "phone": "__RAND_PHONE_3__"
            },
            "docs": []
          },
          {
            "__PAX_MIN__": 4,
            "passengerId": "PAX-4",
            "type": "ADT",
            "givenName": "__RAND_GIVEN_NAME_4__",
            "surname": "__RAND_SURNAME_4__",
            "dob": "__RAND_DOB_4__",
            "gender": "__RAND_GENDER_4__",
            "loyaltyNumber": null,
            "contacts": {
              "email": "__RAND_EMAIL_4__",
              "phone": "__RAND_PHONE_4__"
            },
            "docs": []
          },
          {
            "__PAX_MIN__": 5,
            "passengerId": "PAX-5",
            "type": "ADT",
            "givenName": "__RAND_GIVEN_NAME_5__",
            "surname": "__RAND_SURNAME_5__",
            "dob": "__RAND_DOB_5__",
            "gender": "__RAND_GENDER_5__",
            "loyaltyNumber": null,
            "contacts": {
              "email": "__RAND_EMAIL_5__",
              "phone": "__RAND_PHONE_5__"
            },
            "docs": []
          },
          {
            "__PAX_MIN__": 6,
            "passengerId": "PAX-6",
            "type": "ADT",
            "givenName": "__RAND_GIVEN_NAME_6__",
            "surname": "__RAND_SURNAME_6__",
            "dob": "__RAND_DOB_6__",
            "gender": "__RAND_GENDER_6__",
            "loyaltyNumber": null,
            "contacts": {
              "email": "__RAND_EMAIL_6__",
              "phone": "__RAND_PHONE_6__"
            },
            "docs": []
          }
        ],
        "dataChain": [
          {
            "field": "basketId",
            "from": "basketId",
            "source": "Step 2 \u2192 response.basketId"
          }
        ]
      },
      "response": {
        "statusCode": 200,
        "body": {
          "basketId": "601255b6-9eed-465a-8ff4-c0e9c378155f",
          "status": "Active",
          "totalFareAmount": 0.0,
          "totalSeatAmount": 0.0,
          "totalBagAmount": 0.0,
          "totalPrice": 0.0,
          "currency": "GBP"
        }
      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK \u2014 PAX-1 saved to the basket. contacts.email and contacts.phone are required for the primary passenger.",
        "keyFields": [
          "basketId",
          "status"
        ],
        "validationNotes": "One entry per passenger up to the random paxCount for this run (1\u20136). passengerIds PAX-1\u2026PAX-N must be referenced consistently. type uses IATA passenger type codes (ADT)."
      }
    },
    {
      "step": 5,
      "name": "Get basket \u2014 verify state",
      "description": "Retrieve the basket to confirm the passenger is saved and the basket is active before payment.",
      "type": "positive",
      "apiCall": {
        "method": "GET",
        "endpoint": "/api/v1/basket/{basketId}",
        "baseUrlRef": "retail",
        "pathParams": {
          "basketId": "from-step-2"
        }
      },
      "request": {
        "headers": {},
        "dataChain": [
          {
            "field": "basketId",
            "from": "basketId",
            "source": "Step 2 \u2192 response.basketId"
          }
        ]
      },
      "response": {
        "statusCode": 200,
        "body": {
          "basketId": "601255b6-9eed-465a-8ff4-c0e9c378155f",
          "channelCode": "WEB",
          "currency": "GBP",
          "basketStatus": "Active",
          "basketData": {
            "flightOffers": [
              {
                "offerId": "d8cf391f-67b2-4ab2-8b3b-423777f5156d",
                "basketItemId": "BI-1",
                "inventoryId": "806e766b-e87d-4153-9b69-bb2e7c4ee7f0",
                "flightNumber": "AX001",
                "aircraftType": "A351",
                "cabinCode": "Y"
              }
            ],
            "passengers": [
              {
                "passengerId": "PAX-1",
                "type": "ADT",
                "givenName": "__RAND_GIVEN_NAME__",
                "surname": "__RAND_SURNAME__"
              }
            ],
            "seats": [],
            "bags": []
          }
        }
      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK \u2014 basket retrieved. basketStatus is Active. PAX-1 is present in passengers. seats array is empty as seat selection was skipped.",
        "keyFields": [
          "basketStatus",
          "basketData.flightOffers",
          "basketData.passengers"
        ],
        "validationNotes": "basketStatus must be Active. flightOffers must contain one entry for AX001. passengers must contain PAX-1. seats must be empty."
      }
    },
    {
      "step": 6,
      "name": "Confirm and pay",
      "description": "Submit payment with a Luhn-valid test card to confirm the basket and create the order. The basket transitions to Confirmed and an orderId and bookingReference are returned.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/basket/{basketId}/confirm",
        "baseUrlRef": "retail",
        "pathParams": {
          "basketId": "from-step-2"
        }
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "payment": {
            "method": "CreditCard",
            "cardNumber": "4111111111111111",
            "expiryDate": "12/28",
            "cvv": "737",
            "cardholderName": "__RAND_GIVEN_NAME__ __RAND_SURNAME__"
          },
          "loyaltyPointsToRedeem": null
        },
        "dataChain": [
          {
            "field": "basketId",
            "from": "basketId",
            "source": "Step 2 \u2192 response.basketId"
          }
        ]
      },
      "response": {
        "statusCode": 201,
        "body": {
          "orderId": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
          "bookingReference": "AX123456",
          "status": "Confirmed",
          "eTickets": [
            {
              "passengerId": "PAX-1",
              "segmentIds": [
                "BI-1"
              ],
              "eTicketNumber": "932-0000000001"
            }
          ]
        }
      },
      "expected": {
        "statusCode": 201,
        "description": "201 Created \u2014 order created for AX001 on 2026-04-07 without seats. The basket is marked Confirmed and the response contains the orderId (GUID) and the human-readable bookingReference.",
        "keyFields": [
          "orderId",
          "bookingReference",
          "status",
          "eTickets"
        ],
        "validationNotes": "cardNumber 4111111111111111 is a standard Luhn-valid Visa test card. On success, basketStatus transitions to Confirmed and confirmedOrderId is populated on the basket resource. loyaltyPointsToRedeem is null for a standard card payment.",
        "assertions": [
          {
            "field": "eTickets",
            "assertion": "count",
            "expected": "__RAND_PAX_COUNT__",
            "description": "One e-ticket must be issued per passenger (matches the paxCount for this run)."
          },
          {
            "field": "eTickets[*].eTicketNumber",
            "assertion": "present",
            "description": "Every e-ticket must carry a non-empty eTicketNumber in the format '932-NNNNNNNNNN'."
          }
        ]
      },
      "chainsTo": [
        {
          "field": "orderId",
          "as": "orderId",
          "usedInSteps": []
        },
        {
          "field": "bookingReference",
          "as": "bookingReference",
          "usedInSteps": []
        }
      ]
    }
  ]
}
