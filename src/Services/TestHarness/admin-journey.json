{
  "journey": {
    "name": "Admin \u2014 user management",
    "description": "End-to-end journey covering staff login via the Admin API, which orchestrates the User microservice for credential validation and JWT issuance. Tests successful login, token shape, wrong password rejection, and missing field validation.",
    "domain": "Admin",
    "baseUrls": [
      {
        "id": "admin",
        "label": "Admin API",
        "url": "https://reservation-system-db-api-admin-ageucwaad3axbxhm.uksouth-01.azurewebsites.net"
      },
      {
        "id": "user",
        "label": "User MS",
        "url": "https://reservation-system-db-microservice-user-frhedyd4dcc6aya8.uksouth-01.azurewebsites.net"
      }
    ]
  },
  "steps": [
    {
      "step": 1,
      "name": "Create employee account",
      "description": "Create a new Apex Air employee user account via the User MS using a randomly generated name, email, and username. This step sets up a known credential set for the Admin API login tests that follow.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/users",
        "baseUrlRef": "user"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "username": "__RAND_GIVEN_NAME__.__RAND_SURNAME__",
          "email": "__RAND_EMAIL__",
          "password": "__RAND_PASSWORD__",
          "firstName": "__RAND_GIVEN_NAME__",
          "lastName": "__RAND_SURNAME__"
        }
      },
      "response": {
        "statusCode": 201
      },
      "expected": {
        "statusCode": 201
      },
      "chainsTo": [
        {
          "field": "userId",
          "usedInSteps": [
            2,
            6
          ]
        }
      ]
    },
    {
      "step": 2,
      "name": "Login \u2014 valid credentials",
      "description": "Authenticate the employee account created in Step 1 via the Admin API using the runtime-generated username and password. Validates that the Admin API correctly orchestrates the User MS, returns a signed JWT, and includes the correct response shape.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/auth/login",
        "baseUrlRef": "admin"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "username": "__RAND_GIVEN_NAME__.__RAND_SURNAME__",
          "password": "__RAND_PASSWORD__"
        },
        "dataChain": [
          {
            "field": "username",
            "source": "Step 1 \u2192 runtime-generated username"
          },
          {
            "field": "password",
            "source": "Step 1 \u2192 runtime-generated password"
          }
        ]
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200
      },
      "chainsTo": [
        {
          "field": "accessToken",
          "usedInSteps": []
        },
        {
          "field": "userId",
          "usedInSteps": []
        }
      ]
    },
    {
      "step": 3,
      "name": "Login \u2014 wrong password",
      "description": "Attempt to authenticate via the Admin API using the correct username from Step 1 but an incorrect password. Validates that the Admin API surfaces the User MS 401 response correctly and does not leak credential details.",
      "type": "negative",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/auth/login",
        "baseUrlRef": "admin"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "username": "__RAND_GIVEN_NAME__.__RAND_SURNAME__",
          "password": "WrongPassword99!"
        },
        "dataChain": [
          {
            "field": "username",
            "source": "Step 1 \u2192 runtime-generated username"
          }
        ]
      },
      "response": {
        "statusCode": 401
      },
      "expected": {
        "statusCode": 401
      },
      "chainsTo": []
    },
    {
      "step": 4,
      "name": "Login \u2014 unknown username",
      "description": "Attempt to authenticate via the Admin API with a username that does not exist. Validates that the response is identical to a wrong-password failure, preventing username enumeration.",
      "type": "negative",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/auth/login",
        "baseUrlRef": "admin"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "username": "unknown.user.99999",
          "password": "__RAND_PASSWORD__"
        }
      },
      "response": {
        "statusCode": 401
      },
      "expected": {
        "statusCode": 401
      },
      "chainsTo": []
    },
    {
      "step": 5,
      "name": "Login \u2014 missing password field",
      "description": "Submit a login request to the Admin API with the password field omitted. Validates that the orchestration layer performs field presence validation before forwarding to the User MS.",
      "type": "negative",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/auth/login",
        "baseUrlRef": "admin"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "username": "__RAND_GIVEN_NAME__.__RAND_SURNAME__"
        }
      },
      "response": {
        "statusCode": 400
      },
      "expected": {
        "statusCode": 400
      },
      "chainsTo": []
    },
    {
      "step": 6,
      "name": "Delete employee account",
      "description": "Delete the employee account created in Step 1 to clean up test data. Confirms that the User MS DELETE endpoint permanently removes the account and returns 204 No Content.",
      "type": "positive",
      "apiCall": {
        "method": "DELETE",
        "endpoint": "/api/v1/users/{userId}",
        "baseUrlRef": "user",
        "pathParams": {
          "userId": "from-step-1"
        }
      },
      "request": {
        "headers": {},
        "body": null,
        "dataChain": [
          {
            "field": "userId",
            "source": "Step 1 \u2192 userId"
          }
        ]
      },
      "response": {
        "statusCode": 204
      },
      "expected": {
        "statusCode": 204
      },
      "chainsTo": []
    }
  ]
}
