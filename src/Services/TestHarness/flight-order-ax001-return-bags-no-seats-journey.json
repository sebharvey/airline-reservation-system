            "assertion": "uniqueCount",
            "expected": "__RAND_PAX_COUNT__",
            "description": "One e-ticket must be issued per passenger (matches the paxCount for this run). Unique e-ticket numbers are counted to avoid double-counting the same ticket appearing across multiple segment order items."
