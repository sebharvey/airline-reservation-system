{
  "journey": {
    "name": "Payment API Test",
    "description": "Tests all Payment microservice endpoints — initialise, authorise, settle, void, and refund — with happy path and negative scenarios.",
    "domain": "Payment",
    "baseUrls": [
      { "id": "payment", "label": "Payment MS", "url": "https://reservation-system-db-microservice-payment-f3amf7a6bmauhjd6.uksouth-01.azurewebsites.net" }
    ]
  },
  "steps": [
    {
      "step": 1,
      "name": "Initialise payment",
      "description": "Create a new payment record. Returns a paymentId (GUID) used in all subsequent operations.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/payment/initialise",
        "baseUrlRef": "payment"
      },
      "request": {
        "headers": { "Content-Type": "application/json" },
        "body": {
          "bookingReference": "TS1234",
          "paymentType": "Fare",
          "method": "CreditCard",
          "currencyCode": "GBP",
          "amount": 250.00,
          "description": "Test payment"
        }
      },
      "response": {
        "statusCode": 201,
        "body": {
          "paymentId": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
          "amount": 250.00,
          "status": "Initialised"
        }
      },
      "expected": {
        "statusCode": 201,
        "description": "201 Created — payment initialised. Returns generated paymentId, amount, and Initialised status.",
        "keyFields": ["paymentId", "amount", "status"],
        "validationNotes": "paymentId is a GUID. status = 'Initialised'. amount matches the request."
      },
      "chainsTo": [
        { "field": "paymentId", "as": "paymentIdA", "usedInSteps": [2, 3, 9, 11, 15, 16] }
      ]
    },
    {
      "step": 2,
