      },
      "chainsTo": [
        { "path": "flights[0].inventoryId", "as": "outLeg1InventoryId", "usedInSteps": [6, 10] },
        { "path": "flights[1].inventoryId", "as": "outLeg2InventoryId", "usedInSteps": [7, 10] },
        { "path": "flights[2].inventoryId", "as": "inLeg1InventoryId",  "usedInSteps": [8, 10] },
        { "path": "flights[3].inventoryId", "as": "inLeg2InventoryId",  "usedInSteps": [9, 10] }
      ]
    },
