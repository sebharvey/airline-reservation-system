{
  "journey": {
    "name": "Bookflow \u2014 return connecting DEL \u2192 LHR \u2192 JFK",
    "description": "End-to-end return booking for a four-leg connecting itinerary: outbound DEL \u2192 LHR (AX412) \u2192 JFK and inbound JFK \u2192 LHR \u2192 DEL (AX411). Two connecting searches are performed \u2014 one per direction \u2014 and all four segment offer IDs are placed in a single basket. Covers connecting search, basket creation, passenger details, seatmap retrieval for all four legs, seat selection across all segments, and payment confirmation.",
    "domain": "Retail",
    "baseUrls": [
      {
        "id": "retail",
        "label": "Retail API",
        "url": "https://reservation-system-db-api-retail-aqasakbxcje0a6eh.uksouth-01.azurewebsites.net"
      }
    ]
  },
  "steps": [
    {
      "step": 1,
      "name": "Search outbound connecting (DEL \u2192 JFK)",
      "description": "Search for connecting itinerary options for the outbound journey from DEL to JFK via LHR. Returns paired itineraries with Leg1 (AX412 DEL \u2192 LHR) and Leg2 (one of AX003/AX005/AX007/AX009 LHR \u2192 JFK) satisfying the 60-minute MCT. The selected Leg1 and Leg2 OfferIds and their SessionIds are forwarded to basket creation.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/search/connecting",
        "baseUrlRef": "retail"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "origin": "DEL",
          "destination": "JFK",
          "departureDate": "__RAND_DEPART_DATE__",
          "paxCount": "__RAND_PAX_COUNT__",
          "bookingType": "Revenue"
        }
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200
      },
      "chainsTo": [
        {
          "path": "itineraries[0].leg1.sessionId",
          "as": "outLeg1SessionId",
          "usedInSteps": [
            3
          ]
        },
        {
          "path": "itineraries[0].leg2.sessionId",
          "as": "outLeg2SessionId",
          "usedInSteps": [
            3
          ]
        },
        {
          "randomArrayPath": "itineraries[*].leg1.cabins[*].fareFamilies[*].offer.offerId",
          "as": "outLeg1OfferId",
          "usedInSteps": [
            3
          ]
        },
        {
          "randomArrayPath": "itineraries[*].leg2.cabins[*].fareFamilies[*].offer.offerId",
          "as": "outLeg2OfferId",
          "usedInSteps": [
            3
          ]
        }
      ]
    },
    {
      "step": 2,
      "name": "Search inbound connecting (JFK \u2192 DEL)",
      "description": "Search for connecting itinerary options for the inbound (return) journey from JFK to DEL via LHR. Returns itineraries pairing a JFK \u2192 LHR leg (one of AX002/AX004/AX006/AX008/AX010) with Leg2 LHR \u2192 DEL (AX411, departs 20:30). All JFK \u2192 LHR arrivals at LHR are earlier than 20:30, so all satisfy the 60-minute MCT for AX411. The selected OfferIds and SessionIds are forwarded to basket creation.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/search/connecting",
        "baseUrlRef": "retail"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "origin": "JFK",
          "destination": "DEL",
          "departureDate": "__RAND_RETURN_DATE__",
          "paxCount": "__RAND_PAX_COUNT__",
          "bookingType": "Revenue"
        }
      },
      "response": {
        "statusCode": 200
      },
      "expected": {
        "statusCode": 200
      },
      "chainsTo": [
        {
          "path": "itineraries[0].leg1.sessionId",
          "as": "inLeg1SessionId",
          "usedInSteps": [
            3
          ]
        },
        {
          "path": "itineraries[0].leg2.sessionId",
          "as": "inLeg2SessionId",
          "usedInSteps": [
            3
          ]
        },
        {
          "randomArrayPath": "itineraries[*].leg1.cabins[*].fareFamilies[*].offer.offerId",
          "as": "inLeg1OfferId",
          "usedInSteps": [
            3
          ]
        },
        {
          "randomArrayPath": "itineraries[*].leg2.cabins[*].fareFamilies[*].offer.offerId",
          "as": "inLeg2OfferId",
          "usedInSteps": [
            3
          ]
        }
      ]
    },
    {
      "step": 3,
      "name": "Create basket \u2014 4 segments",
      "description": "Create a basket containing all four segments: outbound Leg1 (DEL \u2192 LHR), outbound Leg2 (LHR \u2192 JFK), inbound Leg1 (JFK \u2192 LHR), and inbound Leg2 (LHR \u2192 DEL). Each segment pairs its OfferId with the SessionId from its respective Offer MS search. The basket holds the complete return itinerary as four independent flight offers.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/basket",
        "baseUrlRef": "retail"
