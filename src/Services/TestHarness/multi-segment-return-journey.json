        "keyFields": ["status"]
      }
    },
    {
      "step": 6,
      "name": "Get outbound Leg1 seatmap (DEL → LHR)",
      "description": "Retrieve the seat map for outbound Leg1 (AX412 DEL → LHR, B789 aircraft). Passing cabinCode restricts the response to the booked cabin only, matching the Web app behaviour.",
      "type": "positive",
      "apiCall": {
        "method": "GET",
        "endpoint": "/api/v1/flights/{flightId}/seatmap?aircraftType={aircraftType}&cabinCode={cabinCode}",
        "baseUrlRef": "retail",
        "pathParams": { "flightId": "from-step-4", "aircraftType": "from-step-4", "cabinCode": "from-step-4" }
      },
      "request": {
        "headers": {},
        "dataChain": [
          { "field": "flightId",    "from": "outLeg1InventoryId",  "source": "Step 4 → basketData.flightOffers[0].inventoryId" },
          { "field": "aircraftType", "from": "outLeg1AircraftType", "source": "Step 4 → basketData.flightOffers[0].aircraftType" },
          { "field": "cabinCode",    "from": "outLeg1CabinCode",    "source": "Step 4 → basketData.flightOffers[0].cabinCode" }
        ]
      },
      "response": {
        "statusCode": 200,
        "body": {
          "flightId": "00000000-0000-0000-0000-000000000001",
          "aircraftType": "B789",
          "cabins": []
