{
  "journey": {
    "name": "Multi-Segment — Return Connecting (DEL → LHR → JFK, JFK → LHR → DEL)",
    "description": "End-to-end return booking for a four-leg connecting itinerary: outbound DEL → LHR (AX412) → JFK and inbound JFK → LHR → DEL (AX411). Two connecting searches are performed — one per direction — and all four segment offer IDs are placed in a single basket. Covers connecting search, basket creation, passenger details, seatmap retrieval for all four legs, seat selection across all segments, and payment confirmation.",
    "domain": "Retail",
    "baseUrls": [
      { "id": "retail", "label": "Retail API", "url": "https://reservation-system-db-api-retail-aqasakbxcje0a6eh.uksouth-01.azurewebsites.net" }
    ]
  },
  "steps": [
    {
      "step": 1,
      "name": "Search outbound connecting (DEL → JFK)",
      "description": "Search for connecting itinerary options for the outbound journey from DEL to JFK via LHR. Returns paired itineraries with Leg1 (AX412 DEL → LHR) and Leg2 (one of AX003/AX005/AX007/AX009 LHR → JFK) satisfying the 60-minute MCT. The selected Leg1 and Leg2 OfferIds and their SessionIds are forwarded to basket creation.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/search/connecting",
        "baseUrlRef": "retail"
      },
      "request": {
        "headers": { "Content-Type": "application/json" },
        "body": {
          "origin": "DEL",
          "destination": "JFK",
          "departureDate": "__RAND_DEPART_DATE__",
          "paxCount": "__RAND_PAX_COUNT__",
          "bookingType": "Revenue"
        }
      },
      "response": {
        "statusCode": 200,
        "body": {
          "itineraries": [
            {
              "leg1": {
                "sessionId": "a1b2c3d4-0001-0001-0001-000000000001",
                "flightNumber": "AX412",
                "origin": "DEL",
                "destination": "LHR",
                "departureDate": "2026-05-20",
                "departureTime": "03:30",
                "arrivalTime": "08:00",
                "arrivalDayOffset": 0,
                "aircraftType": "B789",
                "cabins": [
                  {
                    "cabinCode": "Y",
                    "availableSeats": 207,
                    "fromPrice": 186.25,
                    "currency": "GBP",
                    "fareFamilies": [
                      { "fareFamily": "Flex",     "offer": { "offerId": "a1b2c3d4-1111-1111-1111-000000000001", "fareBasisCode": "YFLEXGB", "basePrice": 249.00, "tax": 97.25, "totalPrice": 346.25, "currency": "GBP", "isRefundable": true,  "isChangeable": true  } },
                      { "fareFamily": "Non-Flex", "offer": { "offerId": "a1b2c3d4-2222-2222-2222-000000000001", "fareBasisCode": "YLOWGB",  "basePrice": 89.00,  "tax": 97.25, "totalPrice": 186.25, "currency": "GBP", "isRefundable": false, "isChangeable": false } }
                    ]
                  }
                ]
              },
              "leg2": {
                "sessionId": "a1b2c3d4-0002-0002-0002-000000000002",
                "flightNumber": "AX003",
                "origin": "LHR",
                "destination": "JFK",
                "departureDate": "2026-05-20",
                "departureTime": "10:30",
                "arrivalTime": "13:45",
                "arrivalDayOffset": 0,
                "aircraftType": "A351",
                "cabins": [
                  {
                    "cabinCode": "Y",
                    "availableSeats": 252,
                    "fromPrice": 186.25,
                    "currency": "GBP",
                    "fareFamilies": [
                      { "fareFamily": "Flex",     "offer": { "offerId": "a1b2c3d4-3333-3333-3333-000000000003", "fareBasisCode": "YFLEXGB", "basePrice": 249.00, "tax": 97.25, "totalPrice": 346.25, "currency": "GBP", "isRefundable": true,  "isChangeable": true  } },
                      { "fareFamily": "Non-Flex", "offer": { "offerId": "a1b2c3d4-4444-4444-4444-000000000004", "fareBasisCode": "YLOWGB",  "basePrice": 89.00,  "tax": 97.25, "totalPrice": 186.25, "currency": "GBP", "isRefundable": false, "isChangeable": false } }
                    ]
                  }
                ]
              },
              "connectionDurationMinutes": 150,
              "combinedFromPrice": 372.50,
              "currency": "GBP"
            }
          ]
        }
      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK — outbound connecting itineraries returned. Each itinerary has Leg1 (DEL → LHR, AX412) and Leg2 (LHR → JFK) satisfying 60-minute MCT. SessionIds for both legs are chained forward for basket creation.",
        "keyFields": ["itineraries", "itineraries[0].connectionDurationMinutes"],
        "validationNotes": "At least one itinerary must be returned. connectionDurationMinutes >= 60 for all itineraries. Leg1 should be AX412 (the only daily DEL → LHR service)."
      },
      "chainsTo": [
        { "path": "itineraries[0].leg1.sessionId", "as": "outLeg1SessionId", "usedInSteps": [3] },
        { "path": "itineraries[0].leg2.sessionId", "as": "outLeg2SessionId", "usedInSteps": [3] },
        { "randomArrayPath": "itineraries[*].leg1.cabins[*].fareFamilies[*].offer.offerId", "as": "outLeg1OfferId", "usedInSteps": [3] },
        { "randomArrayPath": "itineraries[*].leg2.cabins[*].fareFamilies[*].offer.offerId", "as": "outLeg2OfferId", "usedInSteps": [3] }
      ]
    },
    {
      "step": 2,
      "name": "Search inbound connecting (JFK → DEL)",
      "description": "Search for connecting itinerary options for the inbound (return) journey from JFK to DEL via LHR. Returns itineraries pairing a JFK → LHR leg (one of AX002/AX004/AX006/AX008/AX010) with Leg2 LHR → DEL (AX411, departs 20:30). All JFK → LHR arrivals at LHR are earlier than 20:30, so all satisfy the 60-minute MCT for AX411. The selected OfferIds and SessionIds are forwarded to basket creation.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/search/connecting",
        "baseUrlRef": "retail"
      },
      "request": {
        "headers": { "Content-Type": "application/json" },
        "body": {
          "origin": "JFK",
          "destination": "DEL",
          "departureDate": "__RAND_RETURN_DATE__",
          "paxCount": "__RAND_PAX_COUNT__",
          "bookingType": "Revenue"
        }
      },
      "response": {
        "statusCode": 200,
        "body": {
          "itineraries": [
            {
              "leg1": {
                "sessionId": "b2c3d4e5-0001-0001-0001-000000000001",
                "flightNumber": "AX002",
                "origin": "JFK",
                "destination": "LHR",
                "departureDate": "2026-06-03",
                "departureTime": "13:00",
                "arrivalTime": "01:15",
                "arrivalDayOffset": 1,
                "aircraftType": "A351",
                "cabins": [
                  {
                    "cabinCode": "Y",
                    "availableSeats": 252,
                    "fromPrice": 186.25,
                    "currency": "GBP",
                    "fareFamilies": [
                      { "fareFamily": "Flex",     "offer": { "offerId": "b2c3d4e5-1111-1111-1111-000000000001", "fareBasisCode": "YFLEXGB", "basePrice": 249.00, "tax": 97.25, "totalPrice": 346.25, "currency": "GBP", "isRefundable": true,  "isChangeable": true  } },
                      { "fareFamily": "Non-Flex", "offer": { "offerId": "b2c3d4e5-2222-2222-2222-000000000001", "fareBasisCode": "YLOWGB",  "basePrice": 89.00,  "tax": 97.25, "totalPrice": 186.25, "currency": "GBP", "isRefundable": false, "isChangeable": false } }
                    ]
                  }
                ]
              },
              "leg2": {
                "sessionId": "b2c3d4e5-0002-0002-0002-000000000002",
                "flightNumber": "AX411",
                "origin": "LHR",
                "destination": "DEL",
                "departureDate": "2026-06-04",
                "departureTime": "20:30",
                "arrivalTime": "09:00",
                "arrivalDayOffset": 1,
                "aircraftType": "B789",
                "cabins": [
                  {
                    "cabinCode": "Y",
                    "availableSeats": 207,
                    "fromPrice": 186.25,
                    "currency": "GBP",
                    "fareFamilies": [
                      { "fareFamily": "Flex",     "offer": { "offerId": "b2c3d4e5-3333-3333-3333-000000000003", "fareBasisCode": "YFLEXGB", "basePrice": 249.00, "tax": 97.25, "totalPrice": 346.25, "currency": "GBP", "isRefundable": true,  "isChangeable": true  } },
                      { "fareFamily": "Non-Flex", "offer": { "offerId": "b2c3d4e5-4444-4444-4444-000000000004", "fareBasisCode": "YLOWGB",  "basePrice": 89.00,  "tax": 97.25, "totalPrice": 186.25, "currency": "GBP", "isRefundable": false, "isChangeable": false } }
                    ]
                  }
                ]
              },
              "connectionDurationMinutes": 1155,
              "combinedFromPrice": 372.50,
              "currency": "GBP"
            }
          ]
        }
      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK — inbound (return) connecting itineraries returned. Each itinerary has Leg1 (JFK → LHR, overnight with arrivalDayOffset=1) and Leg2 (LHR → DEL, AX411) satisfying 60-minute MCT on the LHR arrival day.",
        "keyFields": ["itineraries", "itineraries[0].connectionDurationMinutes"],
        "validationNotes": "itineraries must be non-empty. Leg2 should be AX411 (the only daily LHR → DEL service). Connection time is large because AX411 departs late (20:30) and all JFK→LHR flights arrive much earlier on the same (next) day."
      },
      "chainsTo": [
        { "path": "itineraries[0].leg1.sessionId", "as": "inLeg1SessionId", "usedInSteps": [3] },
        { "path": "itineraries[0].leg2.sessionId", "as": "inLeg2SessionId", "usedInSteps": [3] },
        { "randomArrayPath": "itineraries[*].leg1.cabins[*].fareFamilies[*].offer.offerId", "as": "inLeg1OfferId", "usedInSteps": [3] },
        { "randomArrayPath": "itineraries[*].leg2.cabins[*].fareFamilies[*].offer.offerId", "as": "inLeg2OfferId", "usedInSteps": [3] }
      ]
    },
    {
      "step": 3,
      "name": "Create basket — 4 segments",
      "description": "Create a basket containing all four segments: outbound Leg1 (DEL → LHR), outbound Leg2 (LHR → JFK), inbound Leg1 (JFK → LHR), and inbound Leg2 (LHR → DEL). Each segment pairs its OfferId with the SessionId from its respective Offer MS search. The basket holds the complete return itinerary as four independent flight offers.",
      "type": "positive",
      "apiCall": {
        "method": "POST",
        "endpoint": "/api/v1/basket",
        "baseUrlRef": "retail"
      },
      "request": {
        "headers": { "Content-Type": "application/json" },
        "body": {
          "segments": [
            { "offerId": "a1b2c3d4-1111-1111-1111-000000000001", "sessionId": "a1b2c3d4-0001-0001-0001-000000000001" },
            { "offerId": "a1b2c3d4-3333-3333-3333-000000000003", "sessionId": "a1b2c3d4-0002-0002-0002-000000000002" },
            { "offerId": "b2c3d4e5-1111-1111-1111-000000000001", "sessionId": "b2c3d4e5-0001-0001-0001-000000000001" },
            { "offerId": "b2c3d4e5-3333-3333-3333-000000000003", "sessionId": "b2c3d4e5-0002-0002-0002-000000000002" }
          ],
          "channelCode": "WEB",
          "currencyCode": "GBP",
          "bookingType": "Revenue",
          "passengerCount": "__RAND_PAX_COUNT__"
        },
        "dataChain": [
          { "field": "segments[0].offerId",   "from": "outLeg1OfferId",   "source": "Step 1 → outbound Leg1 DEL→LHR offer" },
          { "field": "segments[0].sessionId", "from": "outLeg1SessionId", "source": "Step 1 → itineraries[0].leg1.sessionId" },
          { "field": "segments[1].offerId",   "from": "outLeg2OfferId",   "source": "Step 1 → outbound Leg2 LHR→JFK offer" },
          { "field": "segments[1].sessionId", "from": "outLeg2SessionId", "source": "Step 1 → itineraries[0].leg2.sessionId" },
          { "field": "segments[2].offerId",   "from": "inLeg1OfferId",    "source": "Step 2 → inbound Leg1 JFK→LHR offer" },
          { "field": "segments[2].sessionId", "from": "inLeg1SessionId",  "source": "Step 2 → itineraries[0].leg1.sessionId" },
          { "field": "segments[3].offerId",   "from": "inLeg2OfferId",    "source": "Step 2 → inbound Leg2 LHR→DEL offer" },
          { "field": "segments[3].sessionId", "from": "inLeg2SessionId",  "source": "Step 2 → itineraries[0].leg2.sessionId" }
        ]
      },
      "response": {
        "statusCode": 201,
        "body": {
          "basketId": "c0ffee00-1234-5678-abcd-000000000002"
        }
      },
      "expected": {
        "statusCode": 201,
        "description": "201 Created — basket created with all four flight segments. Returns basketId (GUID). The basket now holds the complete return itinerary — two outbound legs and two inbound legs — as independent flight offers.",
        "keyFields": ["basketId"],
        "validationNotes": "basketId is a GUID. All four segments must be accepted. Each offer is independently validated against its stored offer in the Offer MS."
      },
      "chainsTo": [
        { "field": "basketId", "usedInSteps": [4, 5, 6, 7, 8, 9, 10, 11] }
      ]
    },
    {
      "step": 4,
      "name": "Get basket — verify 4 flights",
      "description": "Retrieve the basket to confirm all four connecting flight segments are present and the basket is Active. Chains the inventoryId of each flight for use in the seatmap and seat selection steps.",
      "type": "positive",
      "apiCall": {
        "method": "GET",
        "endpoint": "/api/v1/basket/{basketId}",
        "baseUrlRef": "retail",
        "pathParams": { "basketId": "from-step-3" }
      },
      "request": {
        "headers": {},
        "dataChain": [
          { "field": "basketId", "from": "basketId", "source": "Step 3 → response.basketId" }
        ]
      },
      "response": {
        "statusCode": 200,
        "body": {
          "basketId": "c0ffee00-1234-5678-abcd-000000000002",
          "basketStatus": "Active",
          "basketData": {
            "flightOffers": [
              { "basketItemId": "BI-1", "flightNumber": "AX412", "origin": "DEL", "destination": "LHR", "cabinCode": "Y", "inventoryId": "00000000-0000-0000-0000-000000000001", "aircraftType": "B789", "totalAmount": 186.25 },
              { "basketItemId": "BI-2", "flightNumber": "AX003", "origin": "LHR", "destination": "JFK", "cabinCode": "Y", "inventoryId": "00000000-0000-0000-0000-000000000002", "aircraftType": "A351", "totalAmount": 186.25 },
              { "basketItemId": "BI-3", "flightNumber": "AX002", "origin": "JFK", "destination": "LHR", "cabinCode": "Y", "inventoryId": "00000000-0000-0000-0000-000000000003", "aircraftType": "A351", "totalAmount": 186.25 },
              { "basketItemId": "BI-4", "flightNumber": "AX411", "origin": "LHR", "destination": "DEL", "cabinCode": "Y", "inventoryId": "00000000-0000-0000-0000-000000000004", "aircraftType": "B789", "totalAmount": 186.25 }
            ],
            "passengers": [],
            "seats": [],
            "bags": []
          }
        }
      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK — basket retrieved. basketStatus is Active. basketData.flightOffers contains all four legs: outbound Leg1 (DEL→LHR), outbound Leg2 (LHR→JFK), inbound Leg1 (JFK→LHR), inbound Leg2 (LHR→DEL). Each entry carries inventoryId and aircraftType used for seatmap retrieval.",
        "keyFields": ["basketStatus", "basketData.flightOffers"],
        "validationNotes": "basketData.flightOffers must contain exactly four items. basketStatus must be 'Active'. Leg sequence order is determined by the order segments were submitted in Step 3.",
        "assertions": [
          { "field": "basketData.flightOffers", "assertion": "count", "expected": 4, "description": "Exactly 4 flight offers must be present in the basket — one per leg of the complete connecting return itinerary." }
        ]
      },
      "chainsTo": [
        { "path": "basketData.flightOffers[0].inventoryId",  "as": "outLeg1InventoryId",  "usedInSteps": [6, 10] },
        { "path": "basketData.flightOffers[0].aircraftType", "as": "outLeg1AircraftType", "usedInSteps": [6] },
        { "path": "basketData.flightOffers[0].cabinCode",    "as": "outLeg1CabinCode",    "usedInSteps": [6] },
        { "path": "basketData.flightOffers[1].inventoryId",  "as": "outLeg2InventoryId",  "usedInSteps": [7, 10] },
        { "path": "basketData.flightOffers[1].aircraftType", "as": "outLeg2AircraftType", "usedInSteps": [7] },
        { "path": "basketData.flightOffers[1].cabinCode",    "as": "outLeg2CabinCode",    "usedInSteps": [7] },
        { "path": "basketData.flightOffers[2].inventoryId",  "as": "inLeg1InventoryId",   "usedInSteps": [8, 10] },
        { "path": "basketData.flightOffers[2].aircraftType", "as": "inLeg1AircraftType",  "usedInSteps": [8] },
        { "path": "basketData.flightOffers[2].cabinCode",    "as": "inLeg1CabinCode",     "usedInSteps": [8] },
        { "path": "basketData.flightOffers[3].inventoryId",  "as": "inLeg2InventoryId",   "usedInSteps": [9, 10] },
        { "path": "basketData.flightOffers[3].aircraftType", "as": "inLeg2AircraftType",  "usedInSteps": [9] },
        { "path": "basketData.flightOffers[3].cabinCode",    "as": "inLeg2CabinCode",     "usedInSteps": [9] }
      ]
    },
    {
      "step": 5,
      "name": "Add passenger",
      "description": "Add passenger details to the basket. Up to six passengers are supported; the actual count is determined at runtime by __RAND_PAX_COUNT__. Each passengerId (PAX-1…PAX-N) will be referenced consistently across all four seat assignments.",
      "type": "positive",
      "apiCall": {
        "method": "PUT",
        "endpoint": "/api/v1/basket/{basketId}/passengers",
        "baseUrlRef": "retail",
        "pathParams": { "basketId": "from-step-3" }
      },
      "request": {
        "headers": { "Content-Type": "application/json" },
        "body": [
          { "__PAX_MIN__": 1, "passengerId": "PAX-1", "type": "ADT", "givenName": "__RAND_GIVEN_NAME__",   "surname": "__RAND_SURNAME__",   "dateOfBirth": "__RAND_DOB__",   "gender": "__RAND_GENDER__",   "loyaltyNumber": null, "contacts": { "email": "__RAND_EMAIL__",   "phone": "__RAND_PHONE__"   }, "travelDocument": null },
