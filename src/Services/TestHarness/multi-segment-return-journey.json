      },
      "expected": {
        "statusCode": 200,
        "description": "200 OK — seatmap returned for outbound Leg1 (DEL → LHR) filtered to the booked cabin. Contains cabin layout and seat availability for the B789 aircraft.",
        "keyFields": ["aircraftType", "cabins"],
        "validationNotes": "aircraftType should be B789 (AX412 aircraft type). Response contains only the booked cabin."
