      "apiCall": {
        "method": "PUT",
        "endpoint": "/api/v1/basket/{basketId}/seats",
        "baseUrlRef": "retail",
        "pathParams": { "basketId": "from-step-3" }
      },
      "request": {
        "headers": { "Content-Type": "application/json" },
        "body": [
