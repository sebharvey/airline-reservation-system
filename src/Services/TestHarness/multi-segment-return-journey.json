      "chainsTo": [
        { "randomAvailableSeatFrom": "cabins", "as": { "seatOfferId": "outLeg1SeatOfferId", "seatNumber": "outLeg1SeatNumber", "position": "outLeg1SeatPosition" }, "usedInSteps": [10] }
