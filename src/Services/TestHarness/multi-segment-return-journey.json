      "type": "positive",
      "apiCall": {
        "method": "GET",
        "endpoint": "/api/v1/flights/{flightId}/seatmap?aircraftType={aircraftType}&cabinCode={cabinCode}",
        "baseUrlRef": "retail",
        "pathParams": { "flightId": "from-step-4", "aircraftType": "from-step-4", "cabinCode": "from-step-4" }
      },
      "request": {
        "headers": {},
        "dataChain": [
